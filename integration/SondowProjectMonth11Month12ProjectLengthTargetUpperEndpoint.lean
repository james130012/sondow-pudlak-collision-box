/-- A natural-coefficient monomial envelope for an arbitrary real-valued upper
function.  This is the data form needed by `thresholdOfMonomial`. -/
structure ProjectLengthNatMonomialEnvelope (U : Nat → Real) : Type where
  coeff : Nat
  degree : Nat
  bound : ∀ n : Nat, U n ≤ (coeff : Real) * ((n : Real) + 1) ^ degree

namespace ProjectLengthNatMonomialEnvelope

/-- Extract a natural-coefficient monomial envelope from the project's
polynomial-bound predicate.  The real coefficient from `is_polynomial_bound` is
rounded upward using the Archimedean `exists_nat_ge` lemma. -/
noncomputable def ofPolynomialBound
    {U : Nat → Real} (hU : _root_.is_polynomial_bound U) :
    ProjectLengthNatMonomialEnvelope U := by
  classical
  let c : Real := Classical.choose hU.nonneg_coefficient
  let hk_exists :
      ∃ k : Nat, 0 ≤ c ∧
        ∀ n : Nat, U n ≤ c * ((n : Real) + 1) ^ k :=
    Classical.choose_spec hU.nonneg_coefficient
  let k : Nat := Classical.choose hk_exists
  have hbound :
      ∀ n : Nat, U n ≤ c * ((n : Real) + 1) ^ k :=
    (Classical.choose_spec hk_exists).2
  let C : Nat := Classical.choose (exists_nat_ge c)
  have hC : c ≤ (C : Real) :=
    Classical.choose_spec (exists_nat_ge c)
  exact
    { coeff := C
      degree := k
      bound := by
        intro n
        have hpow_nonneg : 0 ≤ ((n : Real) + 1) ^ k := by
          positivity
        exact (hbound n).trans
          (mul_le_mul_of_nonneg_right hC hpow_nonneg) }

theorem bound_ofPolynomialBound
    {U : Nat → Real} (hU : _root_.is_polynomial_bound U) (n : Nat) :
    U n ≤
      ((ofPolynomialBound hU).coeff : Real) *
        ((n : Real) + 1) ^ (ofPolynomialBound hU).degree :=
  (ofPolynomialBound hU).bound n

end ProjectLengthNatMonomialEnvelope

/-- Explicit selector for a natural-coefficient monomial envelope of each
polynomial upper function.  The selector must choose `(coeff, degree)` from the
function `U` itself, while the `bound` field certifies correctness for any
polynomial-bound proof.  This is the computation-facing replacement for letting
`ProjectLengthNatMonomialEnvelope.ofPolynomialBound` choose data from a proof. -/
structure ProjectLengthPolynomialEnvelopeSelector where
  coeff : (Nat → Real) → Nat
  degree : (Nat → Real) → Nat
  bound :
    ∀ U : Nat → Real, _root_.is_polynomial_bound U →
      ∀ n : Nat, U n ≤ (coeff U : Real) * ((n : Real) + 1) ^ degree U

namespace ProjectLengthPolynomialEnvelopeSelector

/-- Classical proof-erased selector obtained from `is_polynomial_bound`.  This
is an audit bridge, not the intended final executable selector: it still uses
classical choice to extract the envelope from the proof. -/
noncomputable def ofPolynomialBound :
    ProjectLengthPolynomialEnvelopeSelector where
  coeff := fun U => by
    classical
    exact if hU : _root_.is_polynomial_bound U then
      (ProjectLengthNatMonomialEnvelope.ofPolynomialBound hU).coeff
    else 0
  degree := fun U => by
    classical
    exact if hU : _root_.is_polynomial_bound U then
      (ProjectLengthNatMonomialEnvelope.ofPolynomialBound hU).degree
    else 0
  bound := by
    intro U hU n
    classical
    simp [hU, ProjectLengthNatMonomialEnvelope.bound_ofPolynomialBound]

@[simp]
theorem ofPolynomialBound_coeff
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) :
    ofPolynomialBound.coeff U =
      (ProjectLengthNatMonomialEnvelope.ofPolynomialBound hU).coeff := by
  classical
  simp [ofPolynomialBound, hU]

@[simp]
theorem ofPolynomialBound_degree
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) :
    ofPolynomialBound.degree U =
      (ProjectLengthNatMonomialEnvelope.ofPolynomialBound hU).degree := by
  classical
  simp [ofPolynomialBound, hU]

/-- Override the generic proof-erased selector at one distinguished upper
function with explicit `(coeff, degree)` data.  This is an audit selector: it
keeps a concrete payload for the generated target upper while retaining a valid
fallback envelope for all other polynomial upper functions. -/
noncomputable def withDistinguished
    (targetU : Nat → Real) (coeff degree : Nat)
    (target_bound :
      ∀ n : Nat, targetU n ≤ (coeff : Real) * ((n : Real) + 1) ^ degree) :
    ProjectLengthPolynomialEnvelopeSelector where
  coeff := fun U => by
    classical
    exact if U = targetU then coeff else ofPolynomialBound.coeff U
  degree := fun U => by
    classical
    exact if U = targetU then degree else ofPolynomialBound.degree U
  bound := by
    intro U hU n
    classical
    by_cases h : U = targetU
    · subst U
      simpa using target_bound n
    · simpa [h] using ofPolynomialBound.bound U hU n

@[simp]
theorem withDistinguished_coeff_target
    (targetU : Nat → Real) (coeff degree : Nat)
    (target_bound :
      ∀ n : Nat, targetU n ≤ (coeff : Real) * ((n : Real) + 1) ^ degree) :
    (withDistinguished targetU coeff degree target_bound).coeff targetU =
      coeff := by
  classical
  simp [withDistinguished]

@[simp]
theorem withDistinguished_degree_target
    (targetU : Nat → Real) (coeff degree : Nat)
    (target_bound :
      ∀ n : Nat, targetU n ≤ (coeff : Real) * ((n : Real) + 1) ^ degree) :
    (withDistinguished targetU coeff degree target_bound).degree targetU =
      degree := by
  classical
  simp [withDistinguished]

end ProjectLengthPolynomialEnvelopeSelector

/-- Generic single-upper certificate driven by monomial lower-envelope data.
This is the reusable endpoint for an actual threshold algorithm: compute a
threshold for the displayed monomial envelope, then the certified large number
is exactly that threshold. -/
theorem projectLengthSingleUpperMonomialLowerEnvelopeCertificate_noFallback
    {scale_data : InternalPudlakTheorem5ScaleData}
    (fallback : _root_.FormulaCode → Nat)
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
    {A B : Nat → L.BoundedFormula α n}
    {target_family :
      _root_.MiniHilbert.ConcreteProofFamily Ax
        (fun m => A m ⊓ B m)}
    (frontier :
      Month9Month10ConcreteLengthCodeTargetInternalTheorem5Frontier
        scale_data target_family)
    (coeff degree : Nat)
    (gap_data :
      ProjectLengthMonomialLowerEnvelopeGapData
        (checkerProjectLengthMeasured
          scale_data frontier.lower_search.checkerSemantics fallback)
        coeff degree)
    (hupper_bound :
      ∀ m : Nat,
        (projectLengthUpperTailCertificateOfConcreteLengthCodeTargetFrontier
          fallback frontier).U m ≤
          (coeff : Real) * ((m : Real) + 1) ^ degree) :
    let upper :=
      projectLengthUpperTailCertificateOfConcreteLengthCodeTargetFrontier
        fallback frontier
    let measured :=
      checkerProjectLengthMeasured
        scale_data frontier.lower_search.checkerSemantics fallback
    let bigN := gap_data.threshold
    upper.upperN = 0 ∧
      PAHilbertAcceptedProofCodeForFormulaCode
        (concretePAHilbertPowerBoundChecker scale_data)
        (scale_data.powerBoundRawCode bigN)
        bigN ∧
        scale_data.powerBoundRawCode bigN =
          _root_.strengthenedPartialConsistencyCode
            (scale_data.scale bigN) ∧
          upper.U bigN < measured bigN ∧
            measured bigN ≤ upper.U bigN ∧
              False := by
  let upper :=
    projectLengthUpperTailCertificateOfConcreteLengthCodeTargetFrontier
      fallback frontier
  let measured :=
    checkerProjectLengthMeasured
      scale_data frontier.lower_search.checkerSemantics fallback
  let upper_gap : TailStrictGapCertificate upper.U measured :=
    gap_data.toTailStrictGapCertificate (U := upper.U) (measured := measured)
      (by
        intro m
        simpa [upper] using hupper_bound m)
  simpa [upper, measured, upper_gap,
    ProjectLengthMonomialLowerEnvelopeGapData.toTailStrictGapCertificate] using
    projectLengthSingleUpperTailGapCertificate_noFallback
      fallback frontier upper_gap

/-- Conj-source specialization of the monomial lower-envelope endpoint.  The
monomial coefficient and degree are computed from the two component proof-family
length bounds, and the generated upper bound is discharged by
`projectLengthConjSourceGeneratedUpper_U_real_bound_from_natPowerData`. -/
theorem projectLengthConjSourceMonomialLowerEnvelopeCertificate_noFallback
    {scale_data : InternalPudlakTheorem5ScaleData}
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
    {A B : Nat → L.BoundedFormula α n}
    (left_family : _root_.MiniHilbert.ConcreteProofFamily Ax A)
    (right_family : _root_.MiniHilbert.ConcreteProofFamily Ax B)
    (time_bound_strict :
      ∀ {a b : Nat}, a < b →
        scale_data.time_constructible_bound a <
          scale_data.time_constructible_bound b)
    (exponent_ne_zero : scale_data.exponent ≠ 0)
    (tail_gap :
      ComputableGapCertificate
        (fun m : Nat =>
          (((left_family.conjIntro right_family)
            |>.rightConjElim
            |>.minCheckedCodeSize m : Nat) : Real)))
    (left_data : ProjectLengthNatPowerUpperData left_family.length)
    (right_data : ProjectLengthNatPowerUpperData right_family.length)
    (left_length_polynomial :
      _root_.is_polynomial_bound
        (_root_.MiniHilbert.nat_bound_as_real left_family.length))
    (right_length_polynomial :
      _root_.is_polynomial_bound
        (_root_.MiniHilbert.nat_bound_as_real right_family.length))
    (gap_data :
      ProjectLengthMonomialLowerEnvelopeGapData
        (checkerProjectLengthMeasured
          scale_data
          ((Month9Month10TimeBoundCanonicalConjIntroTargetTailGapFrontier.concreteLengthCodeFrontier
            (projectLengthTimeBoundTailGapFrontier
              left_family right_family
              (fun m : Nat =>
                ((left_family.conjIntro right_family)
                  |>.rightConjElim
                  |>.minCheckedCodeSize m))
              time_bound_strict exponent_ne_zero tail_gap (by intro m; rfl)
              left_length_polynomial right_length_polynomial)
            ).lower_search.checkerSemantics)
          (fun _ => 0))
        (projectLengthConjIntroLengthAddTwoNatPowerUpperData
          left_family right_family left_data right_data).coeff
        (projectLengthConjIntroLengthAddTwoNatPowerUpperData
          left_family right_family left_data right_data).degree) :
    let lengthCodeAt :=
      fun m : Nat =>
        ((left_family.conjIntro right_family)
          |>.rightConjElim
          |>.minCheckedCodeSize m)
    let fallback : _root_.FormulaCode → Nat := fun _ => 0
    let frontier :=
      projectLengthTimeBoundTailGapFrontier
        left_family right_family lengthCodeAt time_bound_strict
        exponent_ne_zero tail_gap (by intro m; rfl)
        left_length_polynomial right_length_polynomial
    let upper :=
      projectLengthUpperTailCertificateOfConcreteLengthCodeTargetFrontier
        fallback frontier.concreteLengthCodeFrontier
    let measured :=
      checkerProjectLengthMeasured
        scale_data frontier.concreteLengthCodeFrontier.lower_search.checkerSemantics
        fallback
    let bigN := gap_data.threshold
    upper.upperN = 0 ∧
      PAHilbertAcceptedProofCodeForFormulaCode
        (concretePAHilbertPowerBoundChecker scale_data)
        (scale_data.powerBoundRawCode bigN)
        bigN ∧
        scale_data.powerBoundRawCode bigN =
          _root_.strengthenedPartialConsistencyCode
            (scale_data.scale bigN) ∧
          upper.U bigN < measured bigN ∧
            measured bigN ≤ upper.U bigN ∧
              False := by
  let lengthCodeAt :=
    fun m : Nat =>
      ((left_family.conjIntro right_family)
        |>.rightConjElim
        |>.minCheckedCodeSize m)
  let fallback : _root_.FormulaCode → Nat := fun _ => 0
  let frontier :=
    projectLengthTimeBoundTailGapFrontier
      left_family right_family lengthCodeAt time_bound_strict
      exponent_ne_zero tail_gap (by intro m; rfl)
      left_length_polynomial right_length_polynomial
  let upper :=
    projectLengthUpperTailCertificateOfConcreteLengthCodeTargetFrontier
      fallback frontier.concreteLengthCodeFrontier
  let measured :=
    checkerProjectLengthMeasured
      scale_data frontier.concreteLengthCodeFrontier.lower_search.checkerSemantics
      fallback
  let upper_data :=
    projectLengthConjIntroLengthAddTwoNatPowerUpperData
      left_family right_family left_data right_data
  have hupper_bound :
      ∀ m : Nat,
        upper.U m ≤
          (upper_data.coeff : Real) * ((m : Real) + 1) ^ upper_data.degree := by
    intro m
    simpa [lengthCodeAt, fallback, frontier, upper, upper_data] using
      projectLengthConjSourceGeneratedUpper_U_real_bound_from_natPowerData
        left_family right_family time_bound_strict exponent_ne_zero tail_gap
        left_data right_data left_length_polynomial right_length_polynomial m
  have hcert :=
    projectLengthSingleUpperMonomialLowerEnvelopeCertificate_noFallback
      fallback frontier.concreteLengthCodeFrontier upper_data.coeff upper_data.degree
      gap_data hupper_bound
  simpa [lengthCodeAt, fallback, frontier, upper, measured] using hcert

