/-- Rational-parameter endpoint with an explicit finite-prefix coefficient for
the Sondow component.  This is the directly computable form: a prefix checker
may supply any concrete `sondowPrefixCoeff`, and the resulting `N` is computed
from that coefficient. -/
def projectLengthS21GraftCanonicalDefaultTargetNatPowerUpperData_of_rationalParameterPartialAcceptedTruthAndSondowPrefixBound
    (h : _root_.S21GraftCanonicalCalibrationPackage)
    (sondowTrace :
      _root_.S21VerifierTraceSoundness _root_.sondowCertificateValidCode)
    (partialTrace :
      _root_.S21VerifierTraceSoundness _root_.partialConsistencyCode)
    (rat : MainSondowRationalParameter)
    (partialTruth : _root_.PartialConsistencyAcceptedTruth)
    (sondowPrefixCoeff : Nat)
    (sondowPrefixBound :
      ∀ n : Nat, n < max 3 rat.q.den →
