/-- Encoder-output certificate form of the checked-lower route.  This is the
same contradiction package as the checked-lower `bigN` certificate, stated
directly at the generic encoder trace output. -/
theorem projectLengthTargetUpperSearchWitnessEncoderTraceOutput_certificate_of_checkedLowerBound_noFallback
    {scale_data : InternalPudlakTheorem5ScaleData}
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
