/-- Classical proof-erased witness extracted from a computable no-small-code
proof-length core.  The underlying computational source is the core's
`computable_search_exclusion`; the classical branch only erases the polynomial
proof argument from the record-facing witness type. -/
noncomputable def classicalProofErasedWitnessOfNoSmallCore
    (core : InternalPudlakTheorem5ComputableFiniteSearchNoSmallCore) :
    (Nat → Real) → Nat → Nat :=
  fun U N => by
    classical
    exact if hU : _root_.is_polynomial_bound U then
      core.computable_search_exclusion.witness U hU N
    else
      0

@[simp]
theorem classicalProofErasedWitnessOfNoSmallCore_eq_coreWitness
    (core : InternalPudlakTheorem5ComputableFiniteSearchNoSmallCore)
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) (N : Nat) :
    classicalProofErasedWitnessOfNoSmallCore core U N =
      core.computable_search_exclusion.witness U hU N := by
  unfold classicalProofErasedWitnessOfNoSmallCore
  classical
  simp [hU]

/-- Build the record-facing computation input directly from the existing
proof-length model/no-small-code core.  This is the proof-length-model route to
the uniform-witness endpoint: the core supplies the lower-search witness, and
`proof_length_eq_conj_source` transports its strict actual-proof-length gap to
the conj-source checked length used by the endpoint. -/
noncomputable def ofNoSmallCoreProofLengthModel
    (core : InternalPudlakTheorem5ComputableFiniteSearchNoSmallCore)
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
    {A B : Nat → L.BoundedFormula α n}
    (left_family : _root_.MiniHilbert.ConcreteProofFamily Ax A)
    (right_family : _root_.MiniHilbert.ConcreteProofFamily Ax B)
    (scale_strict :
      ∀ {a b : Nat}, a < b → core.scale_data.scale a < core.scale_data.scale b)
    (time_bound_strict :
      ∀ {a b : Nat}, a < b →
        core.scale_data.time_constructible_bound a <
          core.scale_data.time_constructible_bound b)
    (exponent_ne_zero : core.scale_data.exponent ≠ 0)
    (proof_length_eq_conj_source :
      ∀ m : Nat,
        _root_.proof_length _root_.ProofSystem.PA
            _root_.ProofLengthMeasure.symbolSize
            (core.scale_data.powerBoundRawCode m) =
          (((left_family.conjIntro right_family)
            |>.rightConjElim
            |>.minCheckedCodeSize m : Nat) : Real))
    (left_length_polynomial :
      _root_.is_polynomial_bound
        (_root_.MiniHilbert.nat_bound_as_real left_family.length))
    (right_length_polynomial :
      _root_.is_polynomial_bound
        (_root_.MiniHilbert.nat_bound_as_real right_family.length)) :
    ProjectLengthTargetUpperConjSourceBySizeUniformSearchWitnessComputationInput
      core.scale_data left_family right_family where
  scale_strict := scale_strict
  time_bound_strict := time_bound_strict
  exponent_ne_zero := exponent_ne_zero
  witness := classicalProofErasedWitnessOfNoSmallCore core
  witness_ge := by
    intro U hU N
    rw [classicalProofErasedWitnessOfNoSmallCore_eq_coreWitness core U hU N]
    exact core.computable_search_exclusion.witness_ge U hU N
  strict_at_witness := by
    intro U hU N
    rw [classicalProofErasedWitnessOfNoSmallCore_eq_coreWitness core U hU N]
    have hstrict :
        U (core.computable_search_exclusion.witness U hU N) <
          actualProofLengthMeasured core.scale_data
            (core.computable_search_exclusion.witness U hU N) := by
      simpa [actualProofLengthGapOfComputableFiniteSearchNoSmallCore] using
        actualProofLengthGapOfComputableFiniteSearchNoSmallCore_strict_at_witness
          core U hU N
    unfold actualProofLengthMeasured at hstrict
    rw [proof_length_eq_conj_source
        (core.computable_search_exclusion.witness U hU N)] at hstrict
    exact hstrict
  proof_length_eq_conj_source := proof_length_eq_conj_source
  left_length_polynomial := left_length_polynomial
  right_length_polynomial := right_length_polynomial

/-- The record input generated from a no-small-code proof-length core computes
the same witness as the core for every polynomial upper and cutoff. -/
theorem ofNoSmallCoreProofLengthModel_witness_eq_core
    (core : InternalPudlakTheorem5ComputableFiniteSearchNoSmallCore)
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
    {A B : Nat → L.BoundedFormula α n}
    (left_family : _root_.MiniHilbert.ConcreteProofFamily Ax A)
    (right_family : _root_.MiniHilbert.ConcreteProofFamily Ax B)
    (scale_strict :
      ∀ {a b : Nat}, a < b → core.scale_data.scale a < core.scale_data.scale b)
    (time_bound_strict :
      ∀ {a b : Nat}, a < b →
        core.scale_data.time_constructible_bound a <
          core.scale_data.time_constructible_bound b)
    (exponent_ne_zero : core.scale_data.exponent ≠ 0)
    (proof_length_eq_conj_source :
      ∀ m : Nat,
        _root_.proof_length _root_.ProofSystem.PA
            _root_.ProofLengthMeasure.symbolSize
            (core.scale_data.powerBoundRawCode m) =
          (((left_family.conjIntro right_family)
            |>.rightConjElim
            |>.minCheckedCodeSize m : Nat) : Real))
    (left_length_polynomial :
      _root_.is_polynomial_bound
        (_root_.MiniHilbert.nat_bound_as_real left_family.length))
    (right_length_polynomial :
      _root_.is_polynomial_bound
        (_root_.MiniHilbert.nat_bound_as_real right_family.length))
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) (N : Nat) :
    (ofNoSmallCoreProofLengthModel core left_family right_family
        scale_strict time_bound_strict exponent_ne_zero
        proof_length_eq_conj_source left_length_polynomial
        right_length_polynomial).witness U N =
      core.computable_search_exclusion.witness U hU N := by
  change classicalProofErasedWitnessOfNoSmallCore core U N =
    core.computable_search_exclusion.witness U hU N
  exact classicalProofErasedWitnessOfNoSmallCore_eq_coreWitness core U hU N

/-- The generated `ComputableSearchGapCertificate` itself preserves the
no-small-code core witness. -/
theorem ofNoSmallCoreProofLengthModel_searchGap_witness_eq_core
    (core : InternalPudlakTheorem5ComputableFiniteSearchNoSmallCore)
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
    {A B : Nat → L.BoundedFormula α n}
    (left_family : _root_.MiniHilbert.ConcreteProofFamily Ax A)
