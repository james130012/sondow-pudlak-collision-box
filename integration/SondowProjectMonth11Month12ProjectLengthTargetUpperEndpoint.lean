                scale_data lengthCodeAt).toProofCodeSemantics.size c <
                coeff * (n + 1) ^ degree + 1)
    (monomial_lt_lengthCodeAt_after :
      ∀ coeff degree n : Nat,
        thresholdOfMonomial coeff degree ≤ n →
          coeff * (n + 1) ^ degree < lengthCodeAt n) :
