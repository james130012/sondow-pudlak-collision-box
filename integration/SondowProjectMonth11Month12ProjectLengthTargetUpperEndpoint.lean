/-- Build a search-gap certificate from a uniform executable witness function.
The witness depends only on the polynomial upper function and cutoff; proof
arguments certify it but do not contribute to the computed value. -/
def computableSearchGapCertificateOfUniformWitness
    {measured : Nat → Real}
    (witness : (Nat → Real) → Nat → Nat)
    (witness_ge :
      ∀ U : Nat → Real, _root_.is_polynomial_bound U →
        ∀ N : Nat, N ≤ witness U N)
    (strict_at_witness :
      ∀ U : Nat → Real, _root_.is_polynomial_bound U →
        ∀ N : Nat, U (witness U N) < measured (witness U N)) :
    ComputableSearchGapCertificate measured where
  gap_for_polynomial_upper := by
    intro U hU
    exact
      { witness := witness U
        witness_ge := witness_ge U hU
        strict_at_witness := strict_at_witness U hU }

@[simp]
theorem computableSearchGapCertificateOfUniformWitness_witness_eq
    {measured : Nat → Real}
    (witness : (Nat → Real) → Nat → Nat)
    (witness_ge :
      ∀ U : Nat → Real, _root_.is_polynomial_bound U →
        ∀ N : Nat, N ≤ witness U N)
    (strict_at_witness :
      ∀ U : Nat → Real, _root_.is_polynomial_bound U →
        ∀ N : Nat, U (witness U N) < measured (witness U N))
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) (N : Nat) :
    ((computableSearchGapCertificateOfUniformWitness
        witness witness_ge strict_at_witness)
      |>.gap_for_polynomial_upper U hU).witness N = witness U N :=
  rfl

theorem computableSearchGapCertificateOfUniformWitness_witness_spec
    {measured : Nat → Real}
    (witness : (Nat → Real) → Nat → Nat)
    (witness_ge :
      ∀ U : Nat → Real, _root_.is_polynomial_bound U →
        ∀ N : Nat, N ≤ witness U N)
    (strict_at_witness :
      ∀ U : Nat → Real, _root_.is_polynomial_bound U →
        ∀ N : Nat, U (witness U N) < measured (witness U N))
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) (N : Nat) :
    N ≤
        ((computableSearchGapCertificateOfUniformWitness
            witness witness_ge strict_at_witness)
          |>.gap_for_polynomial_upper U hU).witness N ∧
      U (((computableSearchGapCertificateOfUniformWitness
            witness witness_ge strict_at_witness)
          |>.gap_for_polynomial_upper U hU).witness N) <
        measured
          (((computableSearchGapCertificateOfUniformWitness
            witness witness_ge strict_at_witness)
            |>.gap_for_polynomial_upper U hU).witness N) :=
  ⟨((computableSearchGapCertificateOfUniformWitness
      witness witness_ge strict_at_witness)
      |>.gap_for_polynomial_upper U hU).witness_ge N,
    ((computableSearchGapCertificateOfUniformWitness
      witness witness_ge strict_at_witness)
      |>.gap_for_polynomial_upper U hU).strict_at_witness N⟩

