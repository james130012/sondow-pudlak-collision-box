      projectLengthUpperTailCertificateOfConcreteLengthCodeTargetFrontier
        fallback frontier.concreteLengthCodeFrontier
    projectLengthConjSourceTailGapBigN_noFallback
        left_family right_family time_bound_strict exponent_ne_zero tail_gap
        left_length_polynomial right_length_polynomial =
      (tail_gap.gap_for_polynomial_upper upper.U upper.polynomial).threshold := by
  simp [projectLengthConjSourceTailGapBigN_noFallback,
    projectLengthExplicitTargetUpperTailGapBigN_of_timeBoundTailGap_noFallback]

