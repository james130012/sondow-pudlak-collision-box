/-- Executable threshold template for reducing a monomial to one higher power:
after `n >= coeff`, the coefficient is absorbed by the extra `(n + 1)` factor. -/
def projectLengthOneHigherPowerThresholdOfMonomial
    (coeff _degree : Nat) : Nat :=
  coeff

@[simp]
theorem projectLengthOneHigherPowerThresholdOfMonomial_eq
    (coeff degree : Nat) :
    projectLengthOneHigherPowerThresholdOfMonomial coeff degree = coeff :=
  rfl

/-- Pure Nat arithmetic core for the one-higher-power threshold template. -/
theorem projectLength_nat_monomial_lt_oneHigherPower_after_coeff
    (coeff degree n : Nat) (hn : coeff ≤ n) :
    coeff * (n + 1) ^ degree < (n + 1) ^ (degree + 1) := by
  have hcoeff : coeff < n + 1 := Nat.lt_succ_of_le hn
  have hpow_pos : 0 < (n + 1) ^ degree :=
    Nat.pow_pos (Nat.succ_pos n)
  have hmul :
      coeff * (n + 1) ^ degree < (n + 1) * (n + 1) ^ degree :=
    Nat.mul_lt_mul_of_pos_right hcoeff hpow_pos
  simpa [pow_succ, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hmul

theorem projectLengthOneHigherPowerThresholdOfMonomial_sound
    (coeff degree n : Nat)
    (hn : projectLengthOneHigherPowerThresholdOfMonomial coeff degree ≤ n) :
    coeff * (n + 1) ^ degree < (n + 1) ^ (degree + 1) := by
  exact projectLength_nat_monomial_lt_oneHigherPower_after_coeff
    coeff degree n hn

/-- If the calibrated length eventually dominates the next power at the same
explicit threshold, then `threshold = coeff` is a valid monomial threshold. -/
theorem projectLength_monomial_lt_lengthCodeAt_after_of_oneHigherPower_lower
    (lengthCodeAt : Nat → Nat)
    (hpower_lower :
      ∀ coeff degree n : Nat,
        projectLengthOneHigherPowerThresholdOfMonomial coeff degree ≤ n →
          (n + 1) ^ (degree + 1) ≤ lengthCodeAt n) :
    ∀ coeff degree n : Nat,
      projectLengthOneHigherPowerThresholdOfMonomial coeff degree ≤ n →
        coeff * (n + 1) ^ degree < lengthCodeAt n := by
  intro coeff degree n hn
  exact lt_of_lt_of_le
    (projectLengthOneHigherPowerThresholdOfMonomial_sound coeff degree n hn)
    (hpower_lower coeff degree n hn)

/-- The Nat monomial used by the executable threshold route is a polynomial
upper function in the legacy real-valued sense. -/
theorem projectLength_natMonomial_asReal_is_polynomial_bound
    (coeff degree : Nat) :
    _root_.is_polynomial_bound
      (fun n : Nat => ((coeff * (n + 1) ^ degree : Nat) : Real)) := by
  refine ⟨(coeff : Real), degree, ?_⟩
  intro n
  simp [Nat.cast_mul, Nat.cast_pow, Nat.cast_add]

/-- Classical search witness obtained from a Prop-level semantic strong Nat
lower bound.  This is intentionally noncomputable: the source lower-bound
record provides `∃ᶠ` existence, not an executable threshold program. -/
noncomputable def semanticStrongNatLowerBoundClassicalMonomialSearchWitness
    (sourceLength : Nat → Nat)
    (hsource : _root_.SemanticStrongNatLowerBound sourceLength)
    (coeff degree N : Nat) : Nat :=
  Classical.choose
    ((Filter.frequently_atTop.mp
      (hsource.frequently_beats_every_polynomial
        (fun n : Nat => ((coeff * (n + 1) ^ degree : Nat) : Real))
        (projectLength_natMonomial_asReal_is_polynomial_bound coeff degree))) N)

/-- Specification of the classical monomial search witness.  It is enough for a
search-gap route at each cutoff `N`, but it is not the tail-threshold contract
required by `thresholdOfMonomial`. -/
theorem semanticStrongNatLowerBoundClassicalMonomialSearchWitness_spec
    (sourceLength : Nat → Nat)
    (hsource : _root_.SemanticStrongNatLowerBound sourceLength)
    (coeff degree N : Nat) :
    N ≤ semanticStrongNatLowerBoundClassicalMonomialSearchWitness
        sourceLength hsource coeff degree N ∧
      coeff *
          (semanticStrongNatLowerBoundClassicalMonomialSearchWitness
            sourceLength hsource coeff degree N + 1) ^ degree <
        sourceLength
          (semanticStrongNatLowerBoundClassicalMonomialSearchWitness
            sourceLength hsource coeff degree N) := by
  have hchoose :=
    Classical.choose_spec
      ((Filter.frequently_atTop.mp
        (hsource.frequently_beats_every_polynomial
          (fun n : Nat => ((coeff * (n + 1) ^ degree : Nat) : Real))
          (projectLength_natMonomial_asReal_is_polynomial_bound coeff degree))) N)
  constructor
  · simpa [semanticStrongNatLowerBoundClassicalMonomialSearchWitness]
      using hchoose.1
  · have hreal :
        ((coeff *
          (semanticStrongNatLowerBoundClassicalMonomialSearchWitness
            sourceLength hsource coeff degree N + 1) ^ degree : Nat) : Real) <
          (sourceLength
            (semanticStrongNatLowerBoundClassicalMonomialSearchWitness
              sourceLength hsource coeff degree N) : Real) := by
      simpa [semanticStrongNatLowerBoundClassicalMonomialSearchWitness,
        gt_iff_lt] using hchoose.2
    exact_mod_cast hreal

/-- Executable monomial search-witness provider for a Nat-valued source length.
Unlike `thresholdOfMonomial`, this is a search contract: for each requested
cutoff `N`, it returns one source index beyond that cutoff where the monomial
is below the source length. -/
structure ProjectLengthNatMonomialSearchWitnessProvider
    (sourceLength : Nat → Nat) : Type where
  witness : Nat → Nat → Nat → Nat
  witness_ge : ∀ coeff degree N : Nat, N ≤ witness coeff degree N
  monomial_lt_source_at_witness :
    ∀ coeff degree N : Nat,
      coeff * (witness coeff degree N + 1) ^ degree <
        sourceLength (witness coeff degree N)

namespace ProjectLengthNatMonomialSearchWitnessProvider

/-- Prop-level semantic strong lower bounds provide a monomial search provider
only by classical choice.  A real executable implementation should replace this
constructor with a concrete `witness` program. -/
noncomputable def ofSemanticStrongNatLowerBound
    {sourceLength : Nat → Nat}
    (hsource : _root_.SemanticStrongNatLowerBound sourceLength) :
    ProjectLengthNatMonomialSearchWitnessProvider sourceLength where
  witness := semanticStrongNatLowerBoundClassicalMonomialSearchWitness
    sourceLength hsource
  witness_ge := by
    intro coeff degree N
    exact (semanticStrongNatLowerBoundClassicalMonomialSearchWitness_spec
      sourceLength hsource coeff degree N).1
  monomial_lt_source_at_witness := by
    intro coeff degree N
    exact (semanticStrongNatLowerBoundClassicalMonomialSearchWitness_spec
      sourceLength hsource coeff degree N).2

@[simp]
theorem ofSemanticStrongNatLowerBound_witness_eq_classical
    {sourceLength : Nat → Nat}
    (hsource : _root_.SemanticStrongNatLowerBound sourceLength)
    (coeff degree N : Nat) :
    (ofSemanticStrongNatLowerBound hsource).witness coeff degree N =
      semanticStrongNatLowerBoundClassicalMonomialSearchWitness
        sourceLength hsource coeff degree N :=
  rfl

def uniformWitness
    {sourceLength : Nat → Nat}
    (provider : ProjectLengthNatMonomialSearchWitnessProvider sourceLength)
    (selector : ProjectLengthPolynomialEnvelopeSelector)
    (U : Nat → Real) (N : Nat) : Nat :=
  provider.witness (selector.coeff U) (selector.degree U) N

theorem uniformWitness_ge
    {sourceLength : Nat → Nat}
    (provider : ProjectLengthNatMonomialSearchWitnessProvider sourceLength)
    (selector : ProjectLengthPolynomialEnvelopeSelector)
    (U : Nat → Real) (_hU : _root_.is_polynomial_bound U) (N : Nat) :
    N ≤ provider.uniformWitness selector U N := by
  exact provider.witness_ge (selector.coeff U) (selector.degree U) N

theorem uniformWitness_strict_at_witness
    {sourceLength : Nat → Nat}
    (provider : ProjectLengthNatMonomialSearchWitnessProvider sourceLength)
    (selector : ProjectLengthPolynomialEnvelopeSelector)
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) (N : Nat) :
    U (provider.uniformWitness selector U N) <
      (sourceLength (provider.uniformWitness selector U N) : Real) := by
  let w := provider.uniformWitness selector U N
  have hbound :
      U w ≤ (selector.coeff U : Real) *
          ((w : Real) + 1) ^ selector.degree U :=
    selector.bound U hU w
  have hnat :
      selector.coeff U * (w + 1) ^ selector.degree U < sourceLength w := by
    simpa [w, uniformWitness] using
      provider.monomial_lt_source_at_witness
        (selector.coeff U) (selector.degree U) N
  have hreal :
      (selector.coeff U : Real) * ((w : Real) + 1) ^ selector.degree U <
        (sourceLength w : Real) := by
    exact_mod_cast hnat
  exact lt_of_le_of_lt hbound hreal

end ProjectLengthNatMonomialSearchWitnessProvider

namespace ProjectLengthNatValuedMonomialLowerEnvelopeProvider

/-- A Nat-valued monomial lower-envelope provider is already strong enough to
act as a monomial search-witness provider: for cutoff `N`, return the larger of
`N` and the provider's eventual threshold.  This is the executable bridge from a
threshold program to the search-style `bigN` endpoint. -/
def toMonomialSearchWitnessProvider
    {sourceLength : Nat → Nat}
    (provider :
      ProjectLengthNatValuedMonomialLowerEnvelopeProvider sourceLength) :
    ProjectLengthNatMonomialSearchWitnessProvider sourceLength where
  witness := fun coeff degree N =>
    max N (provider.thresholdOfMonomial coeff degree)
  witness_ge := by
    intro coeff degree N
    exact Nat.le_max_left N (provider.thresholdOfMonomial coeff degree)
  monomial_lt_source_at_witness := by
    intro coeff degree N
    let w := max N (provider.thresholdOfMonomial coeff degree)
    have hthreshold :
        provider.thresholdOfMonomial coeff degree ≤ w := by
      exact Nat.le_max_right N (provider.thresholdOfMonomial coeff degree)
    have hlt_lower :
        coeff * (w + 1) ^ degree < provider.lowerNat w :=
      provider.monomial_lt_lowerNat_after coeff degree w hthreshold
    exact lt_of_lt_of_le hlt_lower (provider.lowerNat_le_lengthCodeAt w)

@[simp]
theorem toMonomialSearchWitnessProvider_witness_eq_max_threshold
    {sourceLength : Nat → Nat}
    (provider :
      ProjectLengthNatValuedMonomialLowerEnvelopeProvider sourceLength)
    (coeff degree N : Nat) :
    (provider.toMonomialSearchWitnessProvider).witness coeff degree N =
      max N (provider.thresholdOfMonomial coeff degree) :=
  rfl

theorem toMonomialSearchWitnessProvider_witness_zero_eq_threshold
    {sourceLength : Nat → Nat}
    (provider :
      ProjectLengthNatValuedMonomialLowerEnvelopeProvider sourceLength)
    (coeff degree : Nat) :
    (provider.toMonomialSearchWitnessProvider).witness coeff degree 0 =
      provider.thresholdOfMonomial coeff degree := by
  simp [toMonomialSearchWitnessProvider]

end ProjectLengthNatValuedMonomialLowerEnvelopeProvider

/-- Computation trace for an executable monomial search witness. -/
structure ProjectLengthMonomialSearchWitnessComputationTrace where
  coeff : Nat
  degree : Nat
  cutoff : Nat
  witness : Nat → Nat → Nat → Nat
  output : Nat
  sound : witness coeff degree cutoff = output

namespace ProjectLengthMonomialSearchWitnessComputationTrace

def ofWitness
    (witness : Nat → Nat → Nat → Nat)
    (coeff degree cutoff : Nat) :
    ProjectLengthMonomialSearchWitnessComputationTrace where
  coeff := coeff
  degree := degree
  cutoff := cutoff
  witness := witness
  output := witness coeff degree cutoff
  sound := rfl

@[simp]
theorem output_ofWitness
    (witness : Nat → Nat → Nat → Nat)
    (coeff degree cutoff : Nat) :
    (ofWitness witness coeff degree cutoff).output =
      witness coeff degree cutoff :=
  rfl

def toCertificate
    (trace : ProjectLengthMonomialSearchWitnessComputationTrace) :
    ProjectLengthTargetUpperBigNCertificate where
  encodedN := trace.output

@[simp]
theorem decode_toCertificate
    (trace : ProjectLengthMonomialSearchWitnessComputationTrace) :
    trace.toCertificate.decode = trace.output :=
  rfl

def toEncoderTrace
    (trace : ProjectLengthMonomialSearchWitnessComputationTrace) :
    ProjectLengthTargetUpperBigNEncoderTrace :=
  ProjectLengthTargetUpperBigNEncoderTrace.ofEncoder
    (ProjectLengthTargetUpperBigNEncoder.ofCertificate trace.toCertificate)

@[simp]
theorem toEncoderTrace_output
    (trace : ProjectLengthMonomialSearchWitnessComputationTrace) :
    trace.toEncoderTrace.output = trace.output :=
  rfl

theorem encoder_eval_eq_output
    (trace : ProjectLengthMonomialSearchWitnessComputationTrace) :
    trace.toEncoderTrace.encoder.eval = trace.output := by
  exact ProjectLengthTargetUpperBigNEncoderTrace.encoder_eval_eq_output
    trace.toEncoderTrace

end ProjectLengthMonomialSearchWitnessComputationTrace

/-- A monomial search-witness provider gives a concrete source-side witness for
the generated target upper.  The output is an encoder-auditable number, lies
past the requested cutoff, and at that same output the generated natural upper
`(conjIntro length) + 2` is strictly below the source min-checked length. -/
theorem projectLengthConjSourceGeneratedUpperNatSearchWitnessTrace_source_spec
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
    {A B : Nat → L.BoundedFormula α n}
    (left_family : _root_.MiniHilbert.ConcreteProofFamily Ax A)
    (right_family : _root_.MiniHilbert.ConcreteProofFamily Ax B)
    (left_data : ProjectLengthNatPowerUpperData left_family.length)
    (right_data : ProjectLengthNatPowerUpperData right_family.length)
    (provider :
      ProjectLengthNatMonomialSearchWitnessProvider
        (fun m : Nat =>
          ((left_family.conjIntro right_family)
            |>.rightConjElim
            |>.minCheckedCodeSize m)))
    (N : Nat) :
    let upper_data :=
      projectLengthConjIntroLengthAddTwoNatPowerUpperData
        left_family right_family left_data right_data
    let trace :=
      ProjectLengthMonomialSearchWitnessComputationTrace.ofWitness
        provider.witness upper_data.coeff upper_data.degree N
    trace.output = provider.witness upper_data.coeff upper_data.degree N ∧
      N ≤ trace.output ∧
        (left_family.conjIntro right_family).length trace.output + 2 <
          ((left_family.conjIntro right_family)
            |>.rightConjElim
            |>.minCheckedCodeSize trace.output) ∧
          trace.toEncoderTrace.encoder.eval = trace.output := by
  let upper_data :=
    projectLengthConjIntroLengthAddTwoNatPowerUpperData
      left_family right_family left_data right_data
  let trace :=
    ProjectLengthMonomialSearchWitnessComputationTrace.ofWitness
      provider.witness upper_data.coeff upper_data.degree N
  have hge : N ≤ trace.output := by
    simpa [trace] using provider.witness_ge upper_data.coeff upper_data.degree N
  have hsource :
      upper_data.coeff * (trace.output + 1) ^ upper_data.degree <
