/-- Canonical S21 graft calibration turns S21 trace soundness for the Sondow
component into a bound for the exposed MiniHilbert proof-family length. -/
theorem s21GraftCanonicalCalibrationPackage_sondow_length_le_proofPredicate_of_trace
    (h : _root_.S21GraftCanonicalCalibrationPackage)
    (htrace :
      _root_.S21VerifierTraceSoundness _root_.sondowCertificateValidCode)
    (n : Nat)
    (hacc :
      _root_.accepted_certificate (_root_.sondowCertificateValidCode n)) :
    (h.sondow_proofs.length n : Real) ≤
      _root_.proof_predicate_formula_size _root_.sondowCertificateValidCode n := by
  have hfamilies :=
    (_root_.s21GraftMiniHilbertCalibration_iff_family_lengths
      h.sondow_proofs h.partial_proofs).1 h.calibration
  have hlen := hfamilies.1 n
  have hbound := htrace.short_proof_from_accepting_trace n hacc
  rwa [hlen] at hbound

/-- Canonical S21 graft calibration turns S21 trace soundness for the
partial-consistency component into a bound for the exposed MiniHilbert
proof-family length. -/
theorem s21GraftCanonicalCalibrationPackage_partial_length_le_proofPredicate_of_trace
