    intro n K code hchecks hsize
    have hsize' : lengthCodeAt code < K := by
      simpa [concretePAHilbertPowerBoundCalibratedCheckerSemantics] using hsize
    exact List.mem_filter.mpr
      ⟨List.mem_range.mpr
