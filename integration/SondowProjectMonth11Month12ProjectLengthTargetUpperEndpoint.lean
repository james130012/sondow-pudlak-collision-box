    exact hno ⟨c, hchecks, hsize_le⟩
  · intro hall hhas
    rcases hhas with ⟨c, hchecks, hsize_le⟩
    exact hall c hsize_le hchecks

/-- No-small-code as a pointwise finite rejection statement with the strict
cutoff convention used by `InternalPudlakTheorem5SmallCodeSearch`: excluding
sizes `≤ K` is the same as rejecting all candidates of size `< K + 1`. -/
theorem not_hasProofCodeOfSize_iff_forall_size_lt_succ_not_checks
    {relevant : _root_.FormulaCode → Prop}
    (sem : _root_.ProofCodeSemantics relevant)
    (code : _root_.FormulaCode) (K : Nat) :
    (¬ sem.HasProofCodeOfSize code K) ↔
      ∀ c : sem.Code, sem.size c < K + 1 → ¬ sem.checks c code := by
  constructor
  · intro hno c hsize_lt hchecks
    exact hno ⟨c, hchecks, Nat.lt_succ_iff.mp hsize_lt⟩
  · intro hall hhas
    rcases hhas with ⟨c, hchecks, hsize_le⟩
    exact hall c (Nat.lt_succ_iff.mpr hsize_le) hchecks

/-- Minimum-size lower bound as a finite rejection statement in strict-cutoff
form.  This is the direct bridge to an enumerator that is complete for proof
