        ¬ sem.checks c (scale_data.powerBoundRawCode n)) :
    K < sem.minProofCodeSize (scale_data.powerBoundRawCode n) ⟨n, rfl⟩ := by
  exact
    (minProofCodeSize_gt_iff_forall_size_lt_succ_not_checks
      sem ⟨n, rfl⟩ K).2
      (finiteRejectionOfCandidateRejection search n (K + 1) hreject)

/-- Convert a strict real inequality between natural-number casts into the
strict-cutoff convention used by finite candidate enumeration. -/
theorem nat_succ_le_of_real_nat_lt
    {K cutoff : Nat} (h : (K : Real) < (cutoff : Real)) :
    K + 1 ≤ cutoff := by
  have hnat : K < cutoff := Nat.cast_lt.mp h
  exact Nat.succ_le_iff.mpr hnat

/-- The Nat-valued monomial payload used by the executable endpoint is itself
an `is_polynomial_bound` target for the search extractor. -/
theorem natMonomialAsReal_is_polynomial_bound (coeff degree : Nat) :
    _root_.is_polynomial_bound
      (fun n : Nat => ((coeff * (n + 1) ^ degree : Nat) : Real)) := by
  refine ⟨(coeff : Real), degree, ?_⟩
  intro n
  norm_num

/-- Candidate-list rejection below a larger cutoff gives the same
`minProofCodeSize` lower bound for any smaller Nat payload `K`. -/
theorem minProofCodeSize_gt_of_candidateRejection_cutoff_ge_succ
    {scale_data : InternalPudlakTheorem5ScaleData}
    {sem :
      _root_.ProofCodeSemantics
        (InternalPudlakTheorem5PowerBoundRelevantCode scale_data)}
    (search : InternalPudlakTheorem5SmallCodeSearch scale_data sem)
    (n cutoff K : Nat)
    (hcutoff : K + 1 ≤ cutoff)
    (hreject :
      ∀ c : sem.Code, c ∈ search.candidates n cutoff →
        ¬ sem.checks c (scale_data.powerBoundRawCode n)) :
    K < sem.minProofCodeSize (scale_data.powerBoundRawCode n) ⟨n, rfl⟩ := by
  exact
    (minProofCodeSize_gt_iff_forall_size_lt_succ_not_checks
      sem ⟨n, rfl⟩ K).2
      (fun c hsize =>
        finiteRejectionOfCandidateRejection search n cutoff hreject c
          (lt_of_lt_of_le hsize hcutoff))

/-- A checker-side rejection extractor proves the `minProofCodeSize` lower
bound whenever its computed cutoff covers the desired Nat payload. -/
theorem minProofCodeSize_gt_of_extractor_cutoff_ge_succ
    {scale_data : InternalPudlakTheorem5ScaleData}
    {checker : InternalPudlakTheorem5CheckerSemantics scale_data}
    {enumeration : InternalPudlakTheorem5CheckerFiniteEnumeration checker}
