/-- A sharper reproof tail for the main Sondow certificate.  The denominator
certificate only needs `q.den ≤ 2 * n`; using the ceiling-half threshold keeps
the same checked certificate while shrinking the finite prefix left for a
separate certificate. -/
def mainSondowFullCertificateCheckedTail_ofReproofRationalParameter_halfDen
    (q : ℚ) (hq : (q : ℝ) = _root_.euler_mascheroni) :
    MainSondowFullCertificateCheckedTail where
  threshold := max 3 ((q.den + 1) / 2)
  checked_at := by
    intro n hn
    have hn_three : 3 ≤ n :=
      le_trans (Nat.le_max_left 3 ((q.den + 1) / 2)) hn
    have hn_half : (q.den + 1) / 2 ≤ n :=
      le_trans (Nat.le_max_right 3 ((q.den + 1) / 2)) hn
    have hden : q.den ≤ 2 * n := by
      omega
    have hn_one : 1 ≤ n :=
      le_trans (by norm_num) hn_three
    exact
      { q := q
        checked :=
          ⟨hq,
            ⟨MainSondowFullCertificateCheckedTail.tail_bound_certificate_accepted_of_three_le
                hn_three,
              _root_.denominator_certificate_accepted_of_den_le q hden⟩,
            _root_.SondowForwardInputs.of_reproof.product_log n hn_one,
            _root_.SondowForwardInputs.of_reproof.decomposition n hn_one⟩ }

