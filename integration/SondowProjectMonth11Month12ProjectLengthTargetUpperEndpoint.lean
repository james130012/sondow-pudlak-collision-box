      InternalPudlakTheorem5SmallCodeSearch scale_data
        (concretePAHilbertPowerBoundCalibratedCheckerSemantics scale_data
          (fun m : Nat =>
            ((left_family.conjIntro right_family)
              |>.rightConjElim
