  let search_gap := data.searchGap
  let input :=
    projectLengthTargetUpperStrictScaleSingletonBySizeInputOfConjSource
      scale_data left_family right_family data.scale_strict search_gap
      data.proof_length_eq_conj_source
  let hsource :
      ∀ m : Nat,
        input.lengthCodeAt m =
          ((left_family.conjIntro right_family)
            |>.rightConjElim
            |>.minCheckedCodeSize m) := by
    intro m
    rfl
