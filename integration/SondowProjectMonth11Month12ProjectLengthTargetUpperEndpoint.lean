@[simp]
theorem ofWitnessZero_output
    {measured : Nat → Real}
    (search_gap : ComputableSearchGapCertificate measured)
    (U : Nat → Real) (polynomial : _root_.is_polynomial_bound U) :
    (ofWitnessZero search_gap U polynomial).output =
      (search_gap.gap_for_polynomial_upper U polynomial).witness 0 :=
  rfl

theorem output_eq_witness_zero
    {measured : Nat → Real}
    {search_gap : ComputableSearchGapCertificate measured}
    (trace : ProjectLengthTargetUpperSearchWitnessTrace search_gap) :
    trace.output =
      (search_gap.gap_for_polynomial_upper
        trace.U trace.polynomial).witness 0 := by
  rw [trace.output_eq_witness, trace.cutoff_eq_zero]

theorem eq_output_iff_eq_witness_zero
    {measured : Nat → Real}
    {search_gap : ComputableSearchGapCertificate measured}
    (trace : ProjectLengthTargetUpperSearchWitnessTrace search_gap)
    (N : Nat) :
    N = trace.output ↔
      N = (search_gap.gap_for_polynomial_upper
        trace.U trace.polynomial).witness 0 := by
  have htrace :
      trace.output =
        (search_gap.gap_for_polynomial_upper
          trace.U trace.polynomial).witness 0 :=
    output_eq_witness_zero trace
  exact ⟨fun h => h.trans htrace, fun h => h.trans htrace.symm⟩

def toCertificate
    {measured : Nat → Real}
    {search_gap : ComputableSearchGapCertificate measured}
    (trace : ProjectLengthTargetUpperSearchWitnessTrace search_gap) :
    ProjectLengthTargetUpperBigNCertificate where
  encodedN := trace.output

@[simp]
theorem decode_toCertificate
    {measured : Nat → Real}
    {search_gap : ComputableSearchGapCertificate measured}
    (trace : ProjectLengthTargetUpperSearchWitnessTrace search_gap) :
    trace.toCertificate.decode = trace.output :=
  rfl

def toEncoderTrace
    {measured : Nat → Real}
    {search_gap : ComputableSearchGapCertificate measured}
    (trace : ProjectLengthTargetUpperSearchWitnessTrace search_gap) :
    ProjectLengthTargetUpperBigNEncoderTrace :=
  ProjectLengthTargetUpperBigNEncoderTrace.ofEncoder
    (ProjectLengthTargetUpperBigNEncoder.ofCertificate trace.toCertificate)

@[simp]
theorem toEncoderTrace_output
    {measured : Nat → Real}
    {search_gap : ComputableSearchGapCertificate measured}
    (trace : ProjectLengthTargetUpperSearchWitnessTrace search_gap) :
    trace.toEncoderTrace.output = trace.output :=
  rfl

theorem eq_output_iff_eq_encoderTraceOutput
    {measured : Nat → Real}
    {search_gap : ComputableSearchGapCertificate measured}
    (trace : ProjectLengthTargetUpperSearchWitnessTrace search_gap)
    (N : Nat) :
    N = trace.output ↔ N = trace.toEncoderTrace.output := by
  exact ⟨fun h => h.trans (toEncoderTrace_output trace).symm,
    fun h => h.trans (toEncoderTrace_output trace)⟩

theorem output_eq_tailGapThreshold_of_toComputableSearchGapCertificate
    {measured : Nat → Real}
    {tail_gap : ComputableGapCertificate measured}
    (trace :
      ProjectLengthTargetUpperSearchWitnessTrace
        tail_gap.toComputableSearchGapCertificate) :
    trace.output =
      (tail_gap.gap_for_polynomial_upper
        trace.U trace.polynomial).threshold := by
  rw [trace.output_eq_witness, trace.cutoff_eq_zero]
  simp [ComputableGapCertificate.toComputableSearchGapCertificate,
    TailStrictGapCertificate.toSearchStrictGapCertificate,
    TailStrictGapCertificate.witness]

/-- Safe comparison between the two trace styles.  This theorem applies only
when the search witness trace was obtained from an actual tail-gap certificate;
it is not available for an arbitrary `frequently` search-gap route. -/
theorem output_eq_tailGapThresholdTraceOutput_of_toComputableSearchGapCertificate
    {measured : Nat → Real}
    {tail_gap : ComputableGapCertificate measured}
    (trace :
      ProjectLengthTargetUpperSearchWitnessTrace
        tail_gap.toComputableSearchGapCertificate) :
    trace.output =
      (ProjectLengthTargetUpperTailGapThresholdTrace.ofThreshold
        tail_gap trace.U trace.polynomial).output := by
  simpa [ProjectLengthTargetUpperTailGapThresholdTrace.ofThreshold] using
    output_eq_tailGapThreshold_of_toComputableSearchGapCertificate trace

end ProjectLengthTargetUpperSearchWitnessTrace

/-- Search-witness trace for a constructor-fed length-code search gap. -/
noncomputable def projectLengthTargetUpperSearchWitnessTrace_of_lengthCodeSearchGap_noFallback
    {scale_data : InternalPudlakTheorem5ScaleData}
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
    {A B : Nat → L.BoundedFormula α n}
    (left_family : _root_.MiniHilbert.ConcreteProofFamily Ax A)
    (right_family : _root_.MiniHilbert.ConcreteProofFamily Ax B)
    (lengthCodeAt : Nat → Nat)
    (time_bound_strict :
      ∀ {a b : Nat}, a < b →
        scale_data.time_constructible_bound a <
          scale_data.time_constructible_bound b)
    (exponent_ne_zero : scale_data.exponent ≠ 0)
    (search_gap :
      ComputableSearchGapCertificate
        (fun m : Nat => (lengthCodeAt m : Real)))
    (lengthCodeAt_eq_conj_source :
      ∀ m : Nat,
        lengthCodeAt m =
          ((left_family.conjIntro right_family)
            |>.rightConjElim
            |>.minCheckedCodeSize m))
    (left_length_polynomial :
      _root_.is_polynomial_bound
        (_root_.MiniHilbert.nat_bound_as_real left_family.length))
    (right_length_polynomial :
      _root_.is_polynomial_bound
        (_root_.MiniHilbert.nat_bound_as_real right_family.length)) :
    ProjectLengthTargetUpperSearchWitnessTrace search_gap :=
  let frontier :=
    timeBoundCanonicalConjIntroTargetSearchFrontierOfLengthCodeSearchGap
      left_family right_family lengthCodeAt time_bound_strict
      exponent_ne_zero search_gap lengthCodeAt_eq_conj_source
      left_length_polynomial right_length_polynomial
  let fallback : _root_.FormulaCode → Nat := fun _ => 0
  let concreteFrontier :=
    frontier.canonicalFrontier.conjIntroLengthCodeFrontier
      |>.concreteLengthCodeFrontier
  let upper :=
    projectLengthUpperTailCertificateOfConcreteLengthCodeTargetFrontier
      fallback concreteFrontier
  ProjectLengthTargetUpperSearchWitnessTrace.ofWitnessZero
    search_gap upper.U upper.polynomial

