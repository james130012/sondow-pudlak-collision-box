/-- Proof-length-free bounded strict-scale search input for the target-upper
route.  This is the clean executable interface: a single bound supplies both
the witness and cutoff, while strict increase of the scale supplies
no-collision below the searched interval. -/
structure ProjectLengthTargetUpperBoundedStrictScaleSearchInput
    (scale_data : InternalPudlakTheorem5ScaleData) : Type where
  bound : ∀ f : Nat → Real, _root_.is_polynomial_bound f → Nat → Nat
  bound_ge :
    ∀ f : Nat → Real, ∀ hf : _root_.is_polynomial_bound f, ∀ N : Nat,
      N ≤ bound f hf N
  bound_gt :
    ∀ f : Nat → Real, ∀ hf : _root_.is_polynomial_bound f, ∀ N : Nat,
      f (bound f hf N) < (bound f hf N : Real)
  scale_strict :
    ∀ {a b : Nat}, a < b → scale_data.scale a < scale_data.scale b

namespace ProjectLengthTargetUpperBoundedStrictScaleSearchInput

def toDominatingScaleNoCollisionRejectionSearchInput
    {scale_data : InternalPudlakTheorem5ScaleData}
    (input :
      ProjectLengthTargetUpperBoundedStrictScaleSearchInput scale_data) :
    ConcretePAHilbertPowerBoundDominatingScaleNoCollisionRejectionSearchInput
      scale_data
      (concretePAHilbertPowerBoundIdentityDominatingLengthInput scale_data)
    where
  witness := input.bound
  cutoff := input.bound
  witness_ge := input.bound_ge
  cutoff_gt := input.bound_gt
  scaleNoCollisionBelow := by
    intro f hf N code hcode_lt hcollision
    have hstrict :
        scale_data.scale code < scale_data.scale (input.bound f hf N) :=
      input.scale_strict hcode_lt
    rw [hcollision] at hstrict
    exact (Nat.lt_irrefl _) hstrict

theorem cutoff_eq_bound
    {scale_data : InternalPudlakTheorem5ScaleData}
    (input :
      ProjectLengthTargetUpperBoundedStrictScaleSearchInput scale_data)
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) (N : Nat) :
    (input.toDominatingScaleNoCollisionRejectionSearchInput).cutoff U hU N =
      input.bound U hU N :=
  rfl

theorem witness_eq_bound
    {scale_data : InternalPudlakTheorem5ScaleData}
    (input :
      ProjectLengthTargetUpperBoundedStrictScaleSearchInput scale_data)
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) (N : Nat) :
    (input.toDominatingScaleNoCollisionRejectionSearchInput).witness U hU N =
      input.bound U hU N :=
  rfl

theorem cutoff_eq_witness
    {scale_data : InternalPudlakTheorem5ScaleData}
    (input :
      ProjectLengthTargetUpperBoundedStrictScaleSearchInput scale_data) :
    ∀ U : Nat → Real, ∀ hU : _root_.is_polynomial_bound U, ∀ N : Nat,
      (input.toDominatingScaleNoCollisionRejectionSearchInput).cutoff U hU N =
        (input.toDominatingScaleNoCollisionRejectionSearchInput).witness
          U hU N := by
  intro U hU N
  rfl

/-- Negative audit for the bounded strict-scale interface.  The field
`bound_gt` asks the same bound to beat every polynomial upper function against
the identity measured value.  Taking `U n = n + 1` shows that this interface is
too strong as a positive route: it would force `w + 1 < w` at
`w = input.bound U hU 0`. -/
theorem false_of_selfPlusOneUpper
    {scale_data : InternalPudlakTheorem5ScaleData}
    (input :
      ProjectLengthTargetUpperBoundedStrictScaleSearchInput scale_data) :
    False := by
  let U : Nat → Real := fun n => (n : Real) + 1
  have hU : _root_.is_polynomial_bound U := by
    refine ⟨1, 1, ?_⟩
    intro n
    simp [U]
  let w := input.bound U hU 0
  have hstrict : U w < (w : Real) :=
    input.bound_gt U hU 0
  dsimp [U] at hstrict
  nlinarith

/-- Audit form of `false_of_selfPlusOneUpper`: the bounded strict-scale
interface is too strong to have a concrete inhabitant.  A positive executable
route must therefore use a measured search-gap certificate rather than asking a
single bound to dominate `U n = n + 1` against the identity value. -/
theorem not_nonempty
    (scale_data : InternalPudlakTheorem5ScaleData) :
    ¬ Nonempty (ProjectLengthTargetUpperBoundedStrictScaleSearchInput scale_data) := by
  rintro ⟨input⟩
  exact false_of_selfPlusOneUpper input

end ProjectLengthTargetUpperBoundedStrictScaleSearchInput

/-- Evaluator trace for a target-upper bound call.  This is the
proof-length-free audit surface for routes that expose the target `bigN` by
evaluating a clean bound rather than by materializing a concrete numeral. -/
structure ProjectLengthTargetUpperBoundEvaluatorTrace
    (bound :
      ∀ U : Nat → Real, _root_.is_polynomial_bound U → Nat → Nat) where
  U : Nat → Real
  polynomial : _root_.is_polynomial_bound U
  cutoff : Nat
  output : Nat
  cutoff_eq_zero : cutoff = 0
  output_eq_bound : output = bound U polynomial cutoff

