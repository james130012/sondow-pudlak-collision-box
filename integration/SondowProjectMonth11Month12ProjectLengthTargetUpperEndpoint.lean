    {bound :
      ∀ U : Nat → Real, _root_.is_polynomial_bound U → Nat → Nat}
    (trace : ProjectLengthTargetUpperBoundEvaluatorTrace bound)
    (hcutoff : trace.cutoff = 0) :
    trace.output = bound trace.U trace.polynomial 0 := by
  rw [trace.output_eq_bound, hcutoff]

