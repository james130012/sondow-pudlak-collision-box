    (measured : Nat → Real) : Type where
  thresholdOf : ∀ U : Nat → Real, _root_.is_polynomial_bound U → Nat
  strict_after_threshold :
    ∀ U : Nat → Real, ∀ hU : _root_.is_polynomial_bound U, ∀ n : Nat,
      thresholdOf U hU ≤ n → U n < measured n

