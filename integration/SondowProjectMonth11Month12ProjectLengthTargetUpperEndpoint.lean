      projectLengthConjIntroLengthAddTwoNatPowerUpperData
        frontier.left_family frontier.right_family left_data right_data
    let f : Nat → Real :=
      fun n : Nat =>
        ((upper_data.coeff * (n + 1) ^ upper_data.degree : Nat) : Real)
    let hf : _root_.is_polynomial_bound f :=
      natMonomialAsReal_is_polynomial_bound upper_data.coeff upper_data.degree
    let bigN := lower.rejectionExtractor.witness f hf N
    let cutoff := lower.rejectionExtractor.cutoff f hf N
    bigN = (lower.gap.gap_for_polynomial_upper f hf).witness N ∧
      cutoff = lower.lengthCodeAt bigN ∧
        N ≤ bigN ∧
          f bigN < (lower.lengthCodeAt bigN : Real) ∧
            (∀ code : lower.checkerSemantics.Code,
              code ∈ lower.finiteEnumeration.candidates bigN cutoff →
                ¬ lower.checkerSemantics.checks code
                  (scale_data.powerBoundRawCode bigN)) := by
  dsimp only
  let lower := frontier.canonicalFrontier.lowerSearch
  let upper_data :=
    projectLengthConjIntroLengthAddTwoNatPowerUpperData
      frontier.left_family frontier.right_family left_data right_data
  let f : Nat → Real :=
    fun n : Nat =>
      ((upper_data.coeff * (n + 1) ^ upper_data.degree : Nat) : Real)
  let hf : _root_.is_polynomial_bound f :=
    natMonomialAsReal_is_polynomial_bound upper_data.coeff upper_data.degree
  let bigN := lower.rejectionExtractor.witness f hf N
  let cutoff := lower.rejectionExtractor.cutoff f hf N
  have htrace :=
    ConcretePAHilbertPowerBoundStrictScaleSingletonSearchInput.rejectionExtractor_gap_trace
      lower
  have hmain := htrace.1 f hf N
  have hreject := htrace.2 f hf N
  have hcutoff : cutoff = lower.lengthCodeAt bigN := by
    have h := hmain.2.1
    rw [← hmain.1] at h
    simpa [lower, upper_data, f, hf, bigN, cutoff] using h
  have hge : N ≤ bigN := by
    have h := hmain.2.2.1
    rw [← hmain.1] at h
    simpa [lower, upper_data, f, hf, bigN] using h
  have hstrict : f bigN < (lower.lengthCodeAt bigN : Real) := by
    have h := hmain.2.2.2
    rw [← hmain.1] at h
    simpa [lower, upper_data, f, hf, bigN] using h
  exact
    ⟨by simpa [lower, upper_data, f, hf, bigN] using hmain.1,
      hcutoff,
      hge,
      hstrict,
      by
        intro code hmem
        simpa [lower, upper_data, f, hf, bigN, cutoff] using
          hreject code hmem⟩

