/-- Pure arithmetic step for the default lower-envelope choice: increasing the
coefficient by one and the degree by one strictly dominates the original
monomial envelope for every natural index. -/
theorem projectLength_monomial_lt_oneDegreeLift
    (coeff degree n : Nat) :
    (coeff : Real) * ((n : Real) + 1) ^ degree <
      ((coeff + 1 : Nat) : Real) * ((n : Real) + 1) ^ (degree + 1) := by
  have hx_one : (1 : Real) ≤ (n : Real) + 1 := by
    nlinarith [show (0 : Real) ≤ (n : Real) by exact Nat.cast_nonneg n]
  have hx_pos : 0 < (n : Real) + 1 := lt_of_lt_of_le zero_lt_one hx_one
  have hxpow_pos : 0 < ((n : Real) + 1) ^ degree :=
    pow_pos hx_pos degree
  have hcoeff : (coeff : Real) < ((coeff + 1 : Nat) : Real) := by
    exact_mod_cast Nat.lt_succ_self coeff
  have hstrict :
      (coeff : Real) * ((n : Real) + 1) ^ degree <
        ((coeff + 1 : Nat) : Real) * ((n : Real) + 1) ^ degree :=
    mul_lt_mul_of_pos_right hcoeff hxpow_pos
  have hpow_le :
      ((n : Real) + 1) ^ degree ≤ ((n : Real) + 1) ^ (degree + 1) :=
    pow_le_pow_right₀ hx_one (Nat.le_succ degree)
  have hlift :
      ((coeff + 1 : Nat) : Real) * ((n : Real) + 1) ^ degree ≤
        ((coeff + 1 : Nat) : Real) * ((n : Real) + 1) ^ (degree + 1) :=
    mul_le_mul_of_nonneg_left hpow_le (Nat.cast_nonneg _)
  exact lt_of_lt_of_le hstrict hlift

/-- Measured lower-bound data for the default one-degree-lift lower envelope.
Supplying this data is now the concrete remaining lower-bound obligation for
the generated upper envelope. -/
structure ProjectLengthOneDegreeLiftMeasuredLowerBound
    (measured : Nat → Real) (coeff degree : Nat) : Type where
  lower_le_measured :
    ∀ n : Nat,
      ((coeff + 1 : Nat) : Real) *
          ((n : Real) + 1) ^ (degree + 1) ≤ measured n

namespace ProjectLengthOneDegreeLiftMeasuredLowerBound

/-- Convert a one-degree-lift measured lower bound into the monomial
lower-envelope gap data with threshold `0`. -/
def toMonomialLowerEnvelopeGapData
    {measured : Nat → Real} {coeff degree : Nat}
    (data : ProjectLengthOneDegreeLiftMeasuredLowerBound measured coeff degree) :
    ProjectLengthMonomialLowerEnvelopeGapData measured coeff degree where
  lower := fun n : Nat =>
    ((coeff + 1 : Nat) : Real) * ((n : Real) + 1) ^ (degree + 1)
  threshold := 0
  monomial_lt_lower_after := by
    intro n _hn
    exact projectLength_monomial_lt_oneDegreeLift coeff degree n
  lower_le_measured := data.lower_le_measured

@[simp]
theorem toMonomialLowerEnvelopeGapData_threshold
    {measured : Nat → Real} {coeff degree : Nat}
    (data : ProjectLengthOneDegreeLiftMeasuredLowerBound measured coeff degree) :
    data.toMonomialLowerEnvelopeGapData.threshold = 0 :=
  rfl

/-- A one-degree-lift lower bound cannot coexist with an upper bound by the
original monomial envelope.  At `n = 0` it would imply `coeff + 1 ≤ coeff`. -/
theorem false_of_upper_bound
    {measured U : Nat → Real} {coeff degree : Nat}
    (lower_data : ProjectLengthOneDegreeLiftMeasuredLowerBound measured coeff degree)
    (hupper : ∀ n : Nat, measured n ≤ U n)
    (hU_bound : ∀ n : Nat,
      U n ≤ (coeff : Real) * ((n : Real) + 1) ^ degree) :
    False := by
  have hlower := lower_data.lower_le_measured 0
  have hmeasured_upper := hupper 0
  have hU := hU_bound 0
  have hU0 : U 0 ≤ (coeff : Real) := by
    simpa using hU
  have hle : ((coeff + 1 : Nat) : Real) ≤ (coeff : Real) := by
    simpa using le_trans hlower (le_trans hmeasured_upper hU0)
  have hlt : (coeff : Real) < ((coeff + 1 : Nat) : Real) := by
    exact_mod_cast Nat.lt_succ_self coeff
  exact (not_lt_of_ge hle) hlt

end ProjectLengthOneDegreeLiftMeasuredLowerBound

