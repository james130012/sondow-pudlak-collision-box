/-- The record output generated from a no-small-code proof-length core is exactly
the core's computable search-exclusion witness at the generated target upper and
cutoff `0`. -/
theorem ofNoSmallCoreProofLengthModel_output_eq_coreWitness_zero
    (core : InternalPudlakTheorem5ComputableFiniteSearchNoSmallCore)
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
    {A B : Nat → L.BoundedFormula α n}
    (left_family : _root_.MiniHilbert.ConcreteProofFamily Ax A)
    (right_family : _root_.MiniHilbert.ConcreteProofFamily Ax B)
    (scale_strict :
      ∀ {a b : Nat}, a < b → core.scale_data.scale a < core.scale_data.scale b)
    (time_bound_strict :
      ∀ {a b : Nat}, a < b →
        core.scale_data.time_constructible_bound a <
          core.scale_data.time_constructible_bound b)
    (exponent_ne_zero : core.scale_data.exponent ≠ 0)
    (proof_length_eq_conj_source :
      ∀ m : Nat,
        _root_.proof_length _root_.ProofSystem.PA
            _root_.ProofLengthMeasure.symbolSize
            (core.scale_data.powerBoundRawCode m) =
          (((left_family.conjIntro right_family)
            |>.rightConjElim
            |>.minCheckedCodeSize m : Nat) : Real))
    (left_length_polynomial :
      _root_.is_polynomial_bound
        (_root_.MiniHilbert.nat_bound_as_real left_family.length))
    (right_length_polynomial :
      _root_.is_polynomial_bound
        (_root_.MiniHilbert.nat_bound_as_real right_family.length)) :
    let data :=
      ofNoSmallCoreProofLengthModel core left_family right_family
        scale_strict time_bound_strict exponent_ne_zero
        proof_length_eq_conj_source left_length_polynomial
        right_length_polynomial
    let search_gap := data.searchGap
    let bySizeInput :=
      projectLengthTargetUpperStrictScaleSingletonBySizeInputOfConjSource
        core.scale_data left_family right_family data.scale_strict search_gap
        data.proof_length_eq_conj_source
    let hsource :
        ∀ m : Nat,
          bySizeInput.lengthCodeAt m =
            ((left_family.conjIntro right_family)
              |>.rightConjElim
              |>.minCheckedCodeSize m) := by
      intro m
      rfl
    let fourPiece :=
      bySizeInput.toStrictScaleSingletonGapCalibratedInput
        |>.toSingletonGapCalibratedFourPieceInput
    let coreFrontier := fourPiece.toCanonicalCalibratedExactnessCore
    let projection :=
      projectLengthTargetUpperConcreteProjectionOfSingletonGapCalibratedFourPieceLengthCodeAtEq
        fourPiece left_family right_family hsource
    let lengthCodeAt_eq_conj_source :
        ∀ m : Nat,
          coreFrontier.checkerSemantics.minProofCodeSizeAt m =
            ((left_family.conjIntro right_family)
              |>.rightConjElim
              |>.minCheckedCodeSize m) :=
      projectLengthTargetUpperCanonicalCore_lengthCodeAt_eq_conj_source_of_concreteProjection
        left_family right_family coreFrontier projection
    let candidate :=
      PAHilbertCanonicalCalibratedExactnessCore.toMonth12UnconditionalCandidate
        coreFrontier
    let lengthCodeAt : Nat → Nat :=
      fun m => coreFrontier.checkerSemantics.minProofCodeSizeAt m
    let actual_gap := actualProofLengthGapConstructor candidate
    let search_gap_core :=
      transportComputableSearchGap
        (fun m => checker_minProofCodeSize_to_actualProofLength candidate m)
        actual_gap
    let frontier :=
      timeBoundCanonicalConjIntroTargetSearchFrontierOfLengthCodeSearchGap
        left_family right_family lengthCodeAt data.time_bound_strict
        data.exponent_ne_zero search_gap_core lengthCodeAt_eq_conj_source
        data.left_length_polynomial data.right_length_polynomial
    let fallback : _root_.FormulaCode → Nat := fun _ => 0
    let concreteFrontier :=
      frontier.canonicalFrontier.conjIntroLengthCodeFrontier
        |>.concreteLengthCodeFrontier
    let upper :=
      projectLengthUpperTailCertificateOfConcreteLengthCodeTargetFrontier
        fallback concreteFrontier
    data.output =
      core.computable_search_exclusion.witness upper.U upper.polynomial 0 := by
  let data :=
    ofNoSmallCoreProofLengthModel core left_family right_family
      scale_strict time_bound_strict exponent_ne_zero
      proof_length_eq_conj_source left_length_polynomial
      right_length_polynomial
  let bound : ∀ U : Nat → Real, _root_.is_polynomial_bound U → Nat → Nat :=
    fun U hU N => core.computable_search_exclusion.witness U hU N
  have hbound :
      ∀ U : Nat → Real, ∀ hU : _root_.is_polynomial_bound U, ∀ N : Nat,
        data.witness U N = bound U hU N := by
    intro U hU N
    simpa [data, bound] using
      ofNoSmallCoreProofLengthModel_witness_eq_core
        core left_family right_family scale_strict time_bound_strict
        exponent_ne_zero proof_length_eq_conj_source left_length_polynomial
        right_length_polynomial U hU N
