/-- Negative audit for the powerBound no-collision search input: taking
`U n = n + 1` puts the witness itself below the cutoff, contradicting
`noCollisionBelow`. -/
theorem noPowerBoundNoCollisionRejectionSearchInput_of_selfPlusOneUpper
    {scale_data : InternalPudlakTheorem5ScaleData}
    (input : ConcretePAHilbertPowerBoundNoCollisionRejectionSearchInput scale_data) :
