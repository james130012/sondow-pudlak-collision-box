/-- Trace for the explicit monomial-threshold computation endpoint.  This is
the executable audit surface for the route whose output is exactly
`thresholdOfMonomial coeff degree`. -/
structure ProjectLengthMonomialThresholdComputationTrace where
  coeff : Nat
  degree : Nat
  thresholdOfMonomial : Nat → Nat → Nat
  output : Nat
  sound : thresholdOfMonomial coeff degree = output

namespace ProjectLengthMonomialThresholdComputationTrace

def ofThreshold
    (thresholdOfMonomial : Nat → Nat → Nat) (coeff degree : Nat) :
    ProjectLengthMonomialThresholdComputationTrace where
  coeff := coeff
  degree := degree
  thresholdOfMonomial := thresholdOfMonomial
  output := thresholdOfMonomial coeff degree
  sound := rfl

@[simp]
theorem output_ofThreshold
    (thresholdOfMonomial : Nat → Nat → Nat) (coeff degree : Nat) :
    (ofThreshold thresholdOfMonomial coeff degree).output =
      thresholdOfMonomial coeff degree :=
  rfl

def toCertificate
    (trace : ProjectLengthMonomialThresholdComputationTrace) :
    ProjectLengthTargetUpperBigNCertificate where
  encodedN := trace.output

@[simp]
theorem decode_toCertificate
    (trace : ProjectLengthMonomialThresholdComputationTrace) :
    trace.toCertificate.decode = trace.output :=
  rfl

def toEncoderTrace
    (trace : ProjectLengthMonomialThresholdComputationTrace) :
    ProjectLengthTargetUpperBigNEncoderTrace :=
  ProjectLengthTargetUpperBigNEncoderTrace.ofEncoder
    (ProjectLengthTargetUpperBigNEncoder.ofCertificate trace.toCertificate)

@[simp]
theorem toEncoderTrace_output
    (trace : ProjectLengthMonomialThresholdComputationTrace) :
    trace.toEncoderTrace.output = trace.output :=
  rfl

theorem encoder_eval_eq_output
    (trace : ProjectLengthMonomialThresholdComputationTrace) :
    trace.toEncoderTrace.encoder.eval = trace.output := by
  exact ProjectLengthTargetUpperBigNEncoderTrace.encoder_eval_eq_output
    trace.toEncoderTrace

end ProjectLengthMonomialThresholdComputationTrace

