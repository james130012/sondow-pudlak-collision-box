/-- Executable maximum of the finite prefix `f 0, ..., f (threshold - 1)`.
The recursive shape is intentionally lightweight and does not require a Finset
enumeration layer. -/
def natPrefixMax (f : Nat → Nat) (threshold : Nat) : Nat :=
  match threshold with
  | 0 => 0
  | .succ t => max (natPrefixMax f t) (f t)

@[simp]
theorem natPrefixMax_zero (f : Nat → Nat) :
    natPrefixMax f 0 = 0 :=
  rfl

@[simp]
theorem natPrefixMax_succ (f : Nat → Nat) (threshold : Nat) :
    natPrefixMax f (threshold + 1) =
      max (natPrefixMax f threshold) (f threshold) :=
  rfl

theorem natPrefixMax_bound {f : Nat → Nat}
    {n threshold : Nat} (hn : n < threshold) :
    f n ≤ natPrefixMax f threshold := by
  induction threshold with
  | zero =>
      exact False.elim (Nat.not_lt_zero n hn)
  | succ t ih =>
      have hnle : n ≤ t := Nat.le_of_lt_succ hn
      rcases Nat.lt_or_eq_of_le hnle with hlt | heq
      · exact Nat.le_trans (ih hlt)
          (Nat.le_max_left (natPrefixMax f t) (f t))
      · subst n
        exact Nat.le_max_right (natPrefixMax f t) (f t)

theorem natPrefixMax_le_of_bound_before {f : Nat → Nat}
    {threshold C : Nat}
    (hbound : ∀ n : Nat, n < threshold → f n ≤ C) :
    natPrefixMax f threshold ≤ C := by
  induction threshold with
  | zero =>
      simp [natPrefixMax]
  | succ t ih =>
      rw [natPrefixMax_succ]
      exact max_le
        (ih (by
          intro n hn
          exact hbound n (Nat.lt_trans hn (Nat.lt_succ_self t))))
        (hbound t (Nat.lt_succ_self t))

/-- The finite prefix maximum is insensitive to pointwise-equal functions. -/
theorem natPrefixMax_congr {f g : Nat → Nat} (threshold : Nat)
    (hfg : ∀ n : Nat, f n = g n) :
    natPrefixMax f threshold = natPrefixMax g threshold := by
  induction threshold with
  | zero =>
      simp [natPrefixMax]
  | succ t ih =>
      rw [natPrefixMax_succ, natPrefixMax_succ, ih, hfg t]

/-- Root proof-length form of the finite Sondow prefix left by a threshold.
This is the computable handoff target after recognition has removed the
opaque proof-family field. -/
def s21SondowProofLengthPrefixMax (threshold : Nat) : Nat :=
  natPrefixMax
    (fun n : Nat =>
      Nat.ceil
        (_root_.proof_length _root_.ProofSystem.S21
          _root_.ProofLengthMeasure.symbolSize
          (_root_.sondowCertificateValidCode n)))
    threshold

/-- The recognition theorem identifies the calibrated Sondow proof-family
prefix maximum with the root S²₁ proof-length prefix maximum. -/
theorem S21GraftProofLengthRecognition_sondowPrefixMax_eq_rootProofLengthPrefixMax
    (hrec : _root_.S21GraftProofLengthRecognitionTheorem)
    (threshold : Nat) :
    natPrefixMax
        (hrec.toLocalProofCodeSemanticsPackage.toCanonicalCalibrationPackage).sondow_proofs.length
        threshold =
      s21SondowProofLengthPrefixMax threshold := by
  unfold s21SondowProofLengthPrefixMax
  apply natPrefixMax_congr
  intro n
  change hrec.sondow_proofs.length n =
    Nat.ceil
      (_root_.proof_length _root_.ProofSystem.S21
        _root_.ProofLengthMeasure.symbolSize
        (_root_.sondowCertificateValidCode n))
  rw [hrec.family_lengths.1 n]
  exact (Nat.ceil_natCast (R := Real) (hrec.sondow_proofs.length n)).symm

/-- MiniHilbert proof-code semantics form of the finite Sondow prefix.  This
removes the global `proof_length` axiom from the remaining finite computation:
the prefix is taken over the explicit proof-code semantics generated by the
recognition theorem's two concrete proof families. -/
noncomputable def s21SondowMiniHilbertMinProofCodeSizePrefixMax
    (hrec : _root_.S21GraftProofLengthRecognitionTheorem)
    (threshold : Nat) : Nat :=
  natPrefixMax
    (fun n : Nat =>
      (_root_.s21GraftMiniHilbertProofCodeSemantics
        hrec.sondow_proofs hrec.partial_proofs).minProofCodeSize
        (_root_.sondowCertificateValidCode n)
        (Or.inl ⟨n, rfl⟩))
    threshold

/-- The calibrated Sondow proof-family prefix maximum is exactly the
MiniHilbert `minProofCodeSize` prefix maximum generated by the recognition
theorem. -/
theorem S21GraftProofLengthRecognition_sondowPrefixMax_eq_miniHilbertMinProofCodeSizePrefixMax
    (hrec : _root_.S21GraftProofLengthRecognitionTheorem)
    (threshold : Nat) :
    natPrefixMax
        (hrec.toLocalProofCodeSemanticsPackage.toCanonicalCalibrationPackage).sondow_proofs.length
        threshold =
      s21SondowMiniHilbertMinProofCodeSizePrefixMax hrec threshold := by
  unfold s21SondowMiniHilbertMinProofCodeSizePrefixMax
  apply natPrefixMax_congr
  intro n
  change hrec.sondow_proofs.length n =
    (_root_.s21GraftMiniHilbertProofCodeSemantics
      hrec.sondow_proofs hrec.partial_proofs).minProofCodeSize
      (_root_.sondowCertificateValidCode n)
      (Or.inl ⟨n, rfl⟩)
  rw [_root_.s21GraftMiniHilbertProofCodeSemantics_minProofCodeSize]
  rfl

