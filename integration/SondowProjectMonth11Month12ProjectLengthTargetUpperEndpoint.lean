/-- The checked Sondow verifier has the explicit predicate-size bound used by
the executable target endpoint.  This exposes the `17` coefficient hidden in
the legacy existential polynomial-bound statement. -/
theorem proofPredicateFormulaSizeSondowCertificateValidCode_le_17_natPower
    (n : Nat) :
    _root_.proof_predicate_formula_size _root_.sondowCertificateValidCode n ≤
      (17 : Real) * ((n : Real) + 1) ^ (1 : Nat) := by
  have hlog := _root_.nat_log2_add_one_le_self_add_one n
  simp [_root_.proof_predicate_formula_size, _root_.verifier_trace_size,
