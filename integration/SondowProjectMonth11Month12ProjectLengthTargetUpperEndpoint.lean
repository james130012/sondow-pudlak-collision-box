def toComputableGapCertificate
    {measured : Nat → Real}
    (provider : ProjectLengthExplicitTailGapProvider measured) :
    ComputableGapCertificate measured where
  gap_for_polynomial_upper := fun U hU =>
    { threshold := provider.thresholdOf U hU
      strict_after := provider.strict_after_threshold U hU }

