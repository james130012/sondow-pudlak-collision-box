/-- Explicit natural-power upper data for the generated conj-source upper
shape.  Since the generated real upper is `(left.conjIntro right).length + 2`,
the natural coefficient is `left.coeff + right.coeff + 3` and the degree is the
maximum of the two component degrees. -/
def projectLengthConjIntroLengthAddTwoNatPowerUpperData
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
    {A B : Nat → L.BoundedFormula α n}
    (left_family : _root_.MiniHilbert.ConcreteProofFamily Ax A)
    (right_family : _root_.MiniHilbert.ConcreteProofFamily Ax B)
    (left_data : ProjectLengthNatPowerUpperData left_family.length)
    (right_data : ProjectLengthNatPowerUpperData right_family.length) :
    ProjectLengthNatPowerUpperData
      (fun m : Nat => (left_family.conjIntro right_family).length m + 2) where
  coeff := left_data.coeff + right_data.coeff + 3
  degree := max left_data.degree right_data.degree
  upper := by
    intro m
    have hcombo :=
      (ProjectLengthNatPowerUpperData.addAddConst
        left_data right_data 3).upper m
    have hlen :
        (left_family.conjIntro right_family).length m =
          left_family.length m + right_family.length m + 1 :=
      left_family.length_conjIntro right_family m
    have hfun :
        (left_family.conjIntro right_family).length m + 2 =
          left_family.length m + right_family.length m + 3 := by
      omega
    simpa [ProjectLengthNatPowerUpperData.addAddConst, hfun] using hcombo

theorem projectLengthConjIntroLengthAddTwoNatPowerUpperData_coeff
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
    {A B : Nat → L.BoundedFormula α n}
    (left_family : _root_.MiniHilbert.ConcreteProofFamily Ax A)
    (right_family : _root_.MiniHilbert.ConcreteProofFamily Ax B)
    (left_data : ProjectLengthNatPowerUpperData left_family.length)
    (right_data : ProjectLengthNatPowerUpperData right_family.length) :
    (projectLengthConjIntroLengthAddTwoNatPowerUpperData
      left_family right_family left_data right_data).coeff =
      left_data.coeff + right_data.coeff + 3 :=
  rfl

theorem projectLengthConjIntroLengthAddTwoNatPowerUpperData_degree
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
    {A B : Nat → L.BoundedFormula α n}
    (left_family : _root_.MiniHilbert.ConcreteProofFamily Ax A)
    (right_family : _root_.MiniHilbert.ConcreteProofFamily Ax B)
