/-- Executable natural-power upper data for a natural-valued length function.
Unlike `is_polynomial_bound`, this stores the coefficient and degree that a
threshold algorithm can inspect. -/
structure ProjectLengthNatPowerUpperData (f : Nat → Nat) : Type where
  coeff : Nat
  degree : Nat
  upper : ∀ n : Nat, f n ≤ coeff * (n + 1) ^ degree

namespace ProjectLengthNatPowerUpperData

/-- The stored natural-power data gives the corresponding real upper bound
pointwise. -/
theorem real_bound {f : Nat → Nat}
    (hf : ProjectLengthNatPowerUpperData f) (n : Nat) :
    _root_.MiniHilbert.nat_bound_as_real f n ≤
      (hf.coeff : Real) * ((n : Real) + 1) ^ hf.degree := by
  have h := hf.upper n
  have hreal :
      (f n : Real) ≤ (hf.coeff * (n + 1) ^ hf.degree : Nat) := by
    exact_mod_cast h
  simpa [_root_.MiniHilbert.nat_bound_as_real] using hreal

/-- Forget the executable coefficient and degree to the legacy proposition
used by existing endpoint code. -/
theorem toPolynomialBound {f : Nat → Nat}
    (hf : ProjectLengthNatPowerUpperData f) :
    _root_.is_polynomial_bound (_root_.MiniHilbert.nat_bound_as_real f) := by
  exact ⟨(hf.coeff : Real), hf.degree, hf.real_bound⟩

/-- Build executable natural-power data from a real-valued monomial bound with
natural coefficient and degree.  This bridges library estimates stated after
casting lengths to `Real` back into the Nat-valued certificate layer. -/
def ofRealMonomialBound {f : Nat → Nat}
    (coeff degree : Nat)
    (hbound :
      ∀ n : Nat, (f n : Real) ≤
        (coeff : Real) * ((n : Real) + 1) ^ degree) :
    ProjectLengthNatPowerUpperData f where
  coeff := coeff
  degree := degree
  upper := by
    intro n
    have hreal :
        (f n : Real) ≤
          (coeff * (n + 1) ^ degree : Nat) := by
      simpa [Nat.cast_mul, Nat.cast_pow, Nat.cast_add] using hbound n
    exact_mod_cast hreal

@[simp]
theorem ofRealMonomialBound_coeff {f : Nat → Nat}
    (coeff degree : Nat)
    (hbound :
      ∀ n : Nat, (f n : Real) ≤
        (coeff : Real) * ((n : Real) + 1) ^ degree) :
    (ofRealMonomialBound coeff degree hbound).coeff = coeff :=
  rfl

@[simp]
theorem ofRealMonomialBound_degree {f : Nat → Nat}
    (coeff degree : Nat)
    (hbound :
      ∀ n : Nat, (f n : Real) ≤
        (coeff : Real) * ((n : Real) + 1) ^ degree) :
    (ofRealMonomialBound coeff degree hbound).degree = degree :=
  rfl

/-- Add a constant to explicit natural-power upper data while preserving an
inspectable coefficient and degree. -/
def addConst {f : Nat → Nat}
    (hf : ProjectLengthNatPowerUpperData f)
    (c : Nat) :
    ProjectLengthNatPowerUpperData (fun n => f n + c) where
  coeff := hf.coeff + c
  degree := hf.degree
  upper := by
    intro n
    have hbase_pos : 0 < n + 1 := Nat.succ_pos n
    have hpow_one : 1 ≤ (n + 1) ^ hf.degree :=
      Nat.one_le_pow hf.degree (n + 1) hbase_pos
    have hc_bound : c ≤ c * (n + 1) ^ hf.degree := by
      simpa [Nat.mul_comm] using Nat.mul_le_mul_left c hpow_one
    calc
      f n + c
          ≤ hf.coeff * (n + 1) ^ hf.degree +
              c * (n + 1) ^ hf.degree := by
            exact Nat.add_le_add (hf.upper n) hc_bound
      _ = (hf.coeff + c) * (n + 1) ^ hf.degree := by
            rw [Nat.add_mul]

@[simp]
theorem addConst_coeff {f : Nat → Nat}
    (hf : ProjectLengthNatPowerUpperData f) (c : Nat) :
    (hf.addConst c).coeff = hf.coeff + c :=
  rfl

@[simp]
theorem addConst_degree {f : Nat → Nat}
    (hf : ProjectLengthNatPowerUpperData f) (c : Nat) :
    (hf.addConst c).degree = hf.degree :=
  rfl

/-- Combine two explicit natural-power upper bounds and a constant term.  This
is the executable-data analogue of the existing `is_polynomial_bound` additivity
lemmas, but it preserves the actual coefficient and degree. -/
def addAddConst {f g : Nat → Nat}
    (hf : ProjectLengthNatPowerUpperData f)
    (hg : ProjectLengthNatPowerUpperData g)
    (c : Nat) :
    ProjectLengthNatPowerUpperData (fun n => f n + g n + c) where
  coeff := hf.coeff + hg.coeff + c
  degree := max hf.degree hg.degree
  upper := by
    intro n
    have hbase_pos : 0 < n + 1 := Nat.succ_pos n
    have hpow_f :
        (n + 1) ^ hf.degree ≤ (n + 1) ^ max hf.degree hg.degree :=
      Nat.pow_le_pow_right hbase_pos (Nat.le_max_left hf.degree hg.degree)
    have hpow_g :
        (n + 1) ^ hg.degree ≤ (n + 1) ^ max hf.degree hg.degree :=
      Nat.pow_le_pow_right hbase_pos (Nat.le_max_right hf.degree hg.degree)
    have hpow_one : 1 ≤ (n + 1) ^ max hf.degree hg.degree :=
      Nat.one_le_pow (max hf.degree hg.degree) (n + 1) hbase_pos
    have hf_bound :
        f n ≤ hf.coeff * (n + 1) ^ max hf.degree hg.degree :=
      le_trans (hf.upper n) (Nat.mul_le_mul_left hf.coeff hpow_f)
    have hg_bound :
        g n ≤ hg.coeff * (n + 1) ^ max hf.degree hg.degree :=
      le_trans (hg.upper n) (Nat.mul_le_mul_left hg.coeff hpow_g)
    have hc_bound :
        c ≤ c * (n + 1) ^ max hf.degree hg.degree := by
      simpa [Nat.mul_comm] using Nat.mul_le_mul_left c hpow_one
    calc
      f n + g n + c
          ≤ hf.coeff * (n + 1) ^ max hf.degree hg.degree +
              hg.coeff * (n + 1) ^ max hf.degree hg.degree +
              c * (n + 1) ^ max hf.degree hg.degree := by
            exact Nat.add_le_add (Nat.add_le_add hf_bound hg_bound) hc_bound
      _ = (hf.coeff + hg.coeff + c) *
            (n + 1) ^ max hf.degree hg.degree := by
            rw [Nat.add_mul, Nat.add_mul]

/-- Transport explicit natural-power data across a pointwise upper bound. -/
def ofLe {f g : Nat → Nat}
    (hg : ProjectLengthNatPowerUpperData g)
    (hfg : ∀ n : Nat, f n ≤ g n) :
    ProjectLengthNatPowerUpperData f where
  coeff := hg.coeff
  degree := hg.degree
  upper := fun n => le_trans (hfg n) (hg.upper n)

@[simp]
theorem ofLe_coeff {f g : Nat → Nat}
    (hg : ProjectLengthNatPowerUpperData g)
    (hfg : ∀ n : Nat, f n ≤ g n) :
    (ofLe hg hfg).coeff = hg.coeff :=
  rfl

@[simp]
theorem ofLe_degree {f g : Nat → Nat}
    (hg : ProjectLengthNatPowerUpperData g)
    (hfg : ∀ n : Nat, f n ≤ g n) :
    (ofLe hg hfg).degree = hg.degree :=
  rfl

/-- Convert an eventual explicit monomial bound plus a finite-prefix bound into
global natural-power upper data.  This is the arithmetic bridge needed when the
large-index certificates come from a trace construction and the small prefix is
handled by finite enumeration. -/
def ofEventuallyBoundAndPrefixBound {f : Nat → Nat}
    (coeff degree threshold prefixCoeff : Nat)
    (eventual :
      ∀ n : Nat, threshold ≤ n →
        f n ≤ coeff * (n + 1) ^ degree)
    (prefixBound :
      ∀ n : Nat, n < threshold → f n ≤ prefixCoeff) :
    ProjectLengthNatPowerUpperData f where
  coeff := max coeff prefixCoeff
  degree := degree
  upper := by
    intro n
    by_cases hn : threshold ≤ n
    · exact le_trans (eventual n hn)
        (Nat.mul_le_mul_right ((n + 1) ^ degree)
          (Nat.le_max_left coeff prefixCoeff))
    · have hnlt : n < threshold := Nat.lt_of_not_ge hn
      have hbase_pos : 0 < n + 1 := Nat.succ_pos n
      have hpow_one : 1 ≤ (n + 1) ^ degree :=
        Nat.one_le_pow degree (n + 1) hbase_pos
      have hprefix_le :
          prefixCoeff ≤ max coeff prefixCoeff * (n + 1) ^ degree := by
        exact le_trans (Nat.le_max_right coeff prefixCoeff)
          (by
            simpa [Nat.mul_comm] using
              Nat.mul_le_mul_left (max coeff prefixCoeff) hpow_one)
      exact le_trans (prefixBound n hnlt) hprefix_le

@[simp]
theorem ofEventuallyBoundAndPrefixBound_coeff {f : Nat → Nat}
    (coeff degree threshold prefixCoeff : Nat)
    (eventual :
      ∀ n : Nat, threshold ≤ n →
        f n ≤ coeff * (n + 1) ^ degree)
    (prefixBound :
      ∀ n : Nat, n < threshold → f n ≤ prefixCoeff) :
    (ofEventuallyBoundAndPrefixBound coeff degree threshold prefixCoeff
      eventual prefixBound).coeff = max coeff prefixCoeff :=
  rfl

@[simp]
theorem ofEventuallyBoundAndPrefixBound_degree {f : Nat → Nat}
    (coeff degree threshold prefixCoeff : Nat)
    (eventual :
      ∀ n : Nat, threshold ≤ n →
        f n ≤ coeff * (n + 1) ^ degree)
    (prefixBound :
      ∀ n : Nat, n < threshold → f n ≤ prefixCoeff) :
    (ofEventuallyBoundAndPrefixBound coeff degree threshold prefixCoeff
      eventual prefixBound).degree = degree :=
  rfl

end ProjectLengthNatPowerUpperData

/-- Explicit natural-power upper data for a conjunction proof family itself.
This is the coefficient data needed when the actual target family is known to
be built by `ConcreteProofFamily.conjIntro`. -/
def projectLengthConjIntroLengthNatPowerUpperData
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
    {A B : Nat → L.BoundedFormula α n}
    (left_family : _root_.MiniHilbert.ConcreteProofFamily Ax A)
    (right_family : _root_.MiniHilbert.ConcreteProofFamily Ax B)
    (left_data : ProjectLengthNatPowerUpperData left_family.length)
    (right_data : ProjectLengthNatPowerUpperData right_family.length) :
    ProjectLengthNatPowerUpperData
      (left_family.conjIntro right_family).length where
  coeff := left_data.coeff + right_data.coeff + 1
  degree := max left_data.degree right_data.degree
  upper := by
    intro m
    have hcombo :=
      (ProjectLengthNatPowerUpperData.addAddConst
        left_data right_data 1).upper m
    have hlen :
        (left_family.conjIntro right_family).length m =
          left_family.length m + right_family.length m + 1 :=
      left_family.length_conjIntro right_family m
    simpa [ProjectLengthNatPowerUpperData.addAddConst, hlen] using hcombo

