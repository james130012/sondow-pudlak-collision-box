/-- If the extractor's polynomial target evaluates to the Nat payload `K` at
its witness, the extractor's own `cutoff_gt` field supplies the cutoff coverage
needed for the minimum-size lower bound. -/
theorem minProofCodeSize_gt_of_extractor_value_eq_nat
    {scale_data : InternalPudlakTheorem5ScaleData}
    {checker : InternalPudlakTheorem5CheckerSemantics scale_data}
    {enumeration : InternalPudlakTheorem5CheckerFiniteEnumeration checker}
    (extractor :
      InternalPudlakTheorem5CheckerComputableRejectionExtractor
        checker enumeration)
