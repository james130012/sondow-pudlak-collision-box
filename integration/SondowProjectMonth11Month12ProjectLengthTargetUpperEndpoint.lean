/-- Checked-lower singleton-gap rejection-extractor normal form.  After building
the proof-length-free strict-scale singleton input from a checked lower bound,
the canonical search-core rejection extractor selects exactly the checked-lower
search-gap witness. -/
theorem strictScaleSingletonGapSearchInput_ofCheckedPowerBoundLowerBound_rejectionExtractor_witness_eq_checkedLowerBoundSearchGap
    {scale_data : InternalPudlakTheorem5ScaleData}
    (lengthCodeAt : Nat → Nat)
    (scale_strict :
      ∀ {a b : Nat}, a < b → scale_data.scale a < scale_data.scale b)
    (checked_lower :
      InternalPudlakTheorem5CheckedPowerBoundLowerBound
        scale_data lengthCodeAt)
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) (N : Nat) :
    let input :=
      ConcretePAHilbertPowerBoundStrictScaleSingletonGapSearchInput.ofCheckedPowerBoundLowerBound
        (scale_data := scale_data) lengthCodeAt scale_strict checked_lower
    let core := input.toCanonicalSearchExactnessCore
    core.rejectionExtractor.witness U hU N =
      ((projectLengthCheckedLowerBoundSearchGap checked_lower)
        |>.gap_for_polynomial_upper U hU).witness N := by
  let input :=
    ConcretePAHilbertPowerBoundStrictScaleSingletonGapSearchInput.ofCheckedPowerBoundLowerBound
      (scale_data := scale_data) lengthCodeAt scale_strict checked_lower
  let core := input.toCanonicalSearchExactnessCore
  calc
    core.rejectionExtractor.witness U hU N =
        (input.gap.gap_for_polynomial_upper U hU).witness N := by
          simpa [input, core] using
            strictScaleSingletonGapSearchInput_rejectionExtractor_witness_eq_gapWitness
              input U hU N
