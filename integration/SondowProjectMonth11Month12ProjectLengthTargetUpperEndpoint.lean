/-- Generic no-small-code equivalence for a proof-code semantics.  The
statement `K < minProofCodeSize code` is exactly the finite exclusion statement
that there is no checked proof code of size at most `K`. -/
theorem minProofCodeSize_gt_iff_not_hasProofCodeOfSize
    {relevant : _root_.FormulaCode → Prop}
    (sem : _root_.ProofCodeSemantics relevant)
    {code : _root_.FormulaCode} (hcode : relevant code) (K : Nat) :
    K < sem.minProofCodeSize code hcode ↔
      ¬ sem.HasProofCodeOfSize code K := by
  constructor
  · intro hlt hhas
    have hmin_le : sem.minProofCodeSize code hcode ≤ K :=
      sem.minProofCodeSize_le_of_hasProofCodeOfSize hcode hhas
    exact (not_lt_of_ge hmin_le) hlt
  · intro hno
    have hnot_le : ¬ sem.minProofCodeSize code hcode ≤ K := by
      intro hmin_le
      rcases sem.hasProofCodeOfSize_minProofCodeSize hcode with
        ⟨c, hchecks, hsize_le_min⟩
      exact hno ⟨c, hchecks, le_trans hsize_le_min hmin_le⟩
    exact Nat.lt_of_not_ge hnot_le

