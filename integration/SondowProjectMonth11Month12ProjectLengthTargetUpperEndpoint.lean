  let candidate :=
    PAHilbertCanonicalCalibratedExactnessCore.toMonth12UnconditionalCandidate
      core
  let lengthCodeAt : Nat → Nat :=
    fun m => core.checkerSemantics.minProofCodeSizeAt m
  let actual_gap := actualProofLengthGapConstructor candidate
  let search_gap_core :=
    transportComputableSearchGap
      (fun m => checker_minProofCodeSize_to_actualProofLength candidate m)
      actual_gap
  let frontier :=
    timeBoundCanonicalConjIntroTargetSearchFrontierOfLengthCodeSearchGap
      left_family right_family lengthCodeAt data.time_bound_strict
      data.exponent_ne_zero search_gap_core lengthCodeAt_eq_conj_source
