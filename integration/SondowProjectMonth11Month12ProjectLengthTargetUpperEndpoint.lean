    refine ⟨1, 1, ?_⟩
    intro n
    simp [U]
  let w := input.witness U hU 0
  let K := input.cutoff U hU 0
  have hcut : U w < (K : Real) := input.cutoff_gt U hU 0
  have hw_lt_K_real : (w : Real) < (K : Real) := by
    dsimp [U] at hcut
    nlinarith
  have hw_lt_K : w < K := by
