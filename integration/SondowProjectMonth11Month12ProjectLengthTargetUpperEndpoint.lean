/-- Candidate-list rejection implies the pointwise finite rejection statement
below the same cutoff.  This is the executable-search bridge: completeness
places every accepted small code into the candidate list, where the checker
rejects it. -/
theorem finiteRejectionOfCandidateRejection
    {scale_data : InternalPudlakTheorem5ScaleData}
    {sem :
      _root_.ProofCodeSemantics
        (InternalPudlakTheorem5PowerBoundRelevantCode scale_data)}
    (search : InternalPudlakTheorem5SmallCodeSearch scale_data sem)
    (n cutoff : Nat)
    (hreject :
      ∀ c : sem.Code, c ∈ search.candidates n cutoff →
        ¬ sem.checks c (scale_data.powerBoundRawCode n)) :
    ∀ c : sem.Code, sem.size c < cutoff →
      ¬ sem.checks c (scale_data.powerBoundRawCode n) := by
  intro c hsize hchecks
  exact hreject c (search.complete n cutoff c hchecks hsize) hchecks

/-- Candidate-list rejection at cutoff `K + 1` gives the exact minimum proof
code-size lower bound `K < minProofCodeSize`. -/
