    (bound :
      ∀ U : Nat → Real, _root_.is_polynomial_bound U → Nat → Nat)
    (U : Nat → Real) (polynomial : _root_.is_polynomial_bound U) :
    ProjectLengthTargetUpperBoundEvaluatorTrace bound where
  U := U
  polynomial := polynomial
  cutoff := 0
  output := bound U polynomial 0
  cutoff_eq_zero := rfl
  output_eq_bound := rfl

