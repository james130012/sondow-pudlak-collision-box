/-- Search-gap certificate generated from the checked lower-bound statement.
This is deliberately the `frequently`-strength route: it provides search
witnesses, not a tail-gap threshold. -/
noncomputable def projectLengthCheckedLowerBoundSearchGap
    {scale_data : InternalPudlakTheorem5ScaleData}
    {lengthCodeAt : Nat → Nat}
    (checked_lower :
      InternalPudlakTheorem5CheckedPowerBoundLowerBound
        scale_data lengthCodeAt) :
    ComputableSearchGapCertificate
      (fun m : Nat => (lengthCodeAt m : Real)) :=
  computableSearchGapCertificateOfFrequentlyStrict
    (fun U hU =>
      (checked_lower U hU).mono (fun _ hn => by
        simpa [gt_iff_lt] using hn))

theorem projectLengthCheckedLowerBoundSearchGap_witness_spec
    {scale_data : InternalPudlakTheorem5ScaleData}
    {lengthCodeAt : Nat → Nat}
    (checked_lower :
      InternalPudlakTheorem5CheckedPowerBoundLowerBound
        scale_data lengthCodeAt)
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) (N : Nat) :
    N ≤
        ((projectLengthCheckedLowerBoundSearchGap checked_lower)
          |>.gap_for_polynomial_upper U hU).witness N ∧
      U (((projectLengthCheckedLowerBoundSearchGap checked_lower)
          |>.gap_for_polynomial_upper U hU).witness N) <
        (lengthCodeAt
          (((projectLengthCheckedLowerBoundSearchGap checked_lower)
            |>.gap_for_polynomial_upper U hU).witness N) : Real) := by
  simpa [projectLengthCheckedLowerBoundSearchGap] using
    computableSearchGapCertificateOfFrequentlyStrict_witness_spec
      (fun U hU =>
        (checked_lower U hU).mono (fun _ hn => by
          simpa [gt_iff_lt] using hn)) U hU N

/-- Witness-exists search gaps expose the exact noncomputable selection point:
the returned witness is definitionally the `Classical.choose` witness. -/
theorem computableSearchGapCertificateOfWitnessExists_witness_eq_choose
    {measured : Nat → Real}
    (hexists :
      ∀ U : Nat → Real, _root_.is_polynomial_bound U →
        ∀ N : Nat, ∃ n : Nat, N ≤ n ∧ U n < measured n)
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) (N : Nat) :
    ((computableSearchGapCertificateOfWitnessExists hexists)
      |>.gap_for_polynomial_upper U hU).witness N =
      Classical.choose (hexists U hU N) := by
  rfl

/-- Frequently-strict search gaps inherit the same noncomputable selection:
the witness is the `Classical.choose` witness produced from the frequent
existence statement at the requested cutoff. -/
theorem computableSearchGapCertificateOfFrequentlyStrict_witness_eq_choose
    {measured : Nat → Real}
    (hfreq :
      ∀ U : Nat → Real, _root_.is_polynomial_bound U →
        ∃ᶠ n in Filter.atTop, U n < measured n)
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) (N : Nat) :
    ((computableSearchGapCertificateOfFrequentlyStrict hfreq)
      |>.gap_for_polynomial_upper U hU).witness N =
      Classical.choose ((Filter.frequently_atTop.mp (hfreq U hU)) N) := by
  rfl

/-- The checked-lower route is classically selected unless it is replaced by an
explicit uniform witness certificate.  This theorem records the exact selection
term so the executable-witness gap is auditable. -/
theorem projectLengthCheckedLowerBoundSearchGap_witness_eq_choose
    {scale_data : InternalPudlakTheorem5ScaleData}
    {lengthCodeAt : Nat → Nat}
    (checked_lower :
      InternalPudlakTheorem5CheckedPowerBoundLowerBound
        scale_data lengthCodeAt)
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) (N : Nat) :
    ((projectLengthCheckedLowerBoundSearchGap checked_lower)
      |>.gap_for_polynomial_upper U hU).witness N =
      Classical.choose
        ((Filter.frequently_atTop.mp
          ((checked_lower U hU).mono (fun _ hn => by
            simpa [gt_iff_lt] using hn))) N) := by
  rfl

@[simp]
theorem computableGapCertificate_toComputableSearchGapCertificate_witness_eq_max
    {measured : Nat → Real}
    (gap : ComputableGapCertificate measured)
    (U : Nat → Real) (hU : _root_.is_polynomial_bound U) (N : Nat) :
    ((gap.toComputableSearchGapCertificate)
      |>.gap_for_polynomial_upper U hU).witness N =
      max N ((gap.gap_for_polynomial_upper U hU).threshold) := by
  rfl

/-- A computable search-gap certificate implies the checked lower-bound
statement.  This is a Prop-level bridge: it proves the lower-bound hypothesis
from explicit witnesses, but it does not claim to preserve the concrete witness
chosen later by `projectLengthCheckedLowerBoundSearchGap`. -/
theorem checkedPowerBoundLowerBoundOfComputableSearchGap
    {scale_data : InternalPudlakTheorem5ScaleData}
    {checkedLength : Nat → Nat}
    (gap :
      ComputableSearchGapCertificate
        (fun n : Nat => (checkedLength n : Real))) :
    InternalPudlakTheorem5CheckedPowerBoundLowerBound
      scale_data checkedLength := by
  intro U hU
  exact Filter.frequently_atTop.mpr (fun N => by
    refine ⟨(gap.gap_for_polynomial_upper U hU).witness N, ?_, ?_⟩
    · exact (gap.gap_for_polynomial_upper U hU).witness_ge N
    · simpa [gt_iff_lt] using
        (gap.gap_for_polynomial_upper U hU).strict_at_witness N)

/-- Any strict-scale singleton by-size input supplies the checked lower-bound
statement for its stored calibrated length. -/
theorem checkedPowerBoundLowerBoundOfStrictScaleSingletonBySizeInput
    {scale_data : InternalPudlakTheorem5ScaleData}
    (input :
      ConcretePAHilbertPowerBoundStrictScaleSingletonBySizeInput
        scale_data) :
    InternalPudlakTheorem5CheckedPowerBoundLowerBound
      scale_data input.lengthCodeAt :=
  checkedPowerBoundLowerBoundOfComputableSearchGap input.gap

/-- Time-bound canonical search frontier generated from the checked lower-bound
statement.  This is the proof-complexity-native input: it uses the existing
`frequently` lower-bound strength and does not require a tail-gap threshold. -/
noncomputable def timeBoundCanonicalConjIntroTargetSearchFrontierOfCheckedLowerBound
    {scale_data : InternalPudlakTheorem5ScaleData}
    {L : _root_.FirstOrder.Language.{u, v}} {α : Type w} {n : Nat}
    {Ax : L.BoundedFormula α n → Prop}
    {A B : Nat → L.BoundedFormula α n}
    (left_family : _root_.MiniHilbert.ConcreteProofFamily Ax A)
    (right_family : _root_.MiniHilbert.ConcreteProofFamily Ax B)
    (lengthCodeAt : Nat → Nat)
    (time_bound_strict :
      ∀ {a b : Nat}, a < b →
        scale_data.time_constructible_bound a <
          scale_data.time_constructible_bound b)
    (exponent_ne_zero : scale_data.exponent ≠ 0)
    (checked_lower :
      InternalPudlakTheorem5CheckedPowerBoundLowerBound
        scale_data lengthCodeAt)
    (lengthCodeAt_eq_conj_source :
      ∀ m : Nat,
        lengthCodeAt m =
          ((left_family.conjIntro right_family)
            |>.rightConjElim
            |>.minCheckedCodeSize m))
    (left_length_polynomial :
      _root_.is_polynomial_bound
        (_root_.MiniHilbert.nat_bound_as_real left_family.length))
    (right_length_polynomial :
      _root_.is_polynomial_bound
        (_root_.MiniHilbert.nat_bound_as_real right_family.length)) :
    Month9Month10TimeBoundCanonicalConjIntroTargetSearchFrontier
      scale_data (Ax := Ax) (A := A) (B := B) :=
  timeBoundCanonicalConjIntroTargetSearchFrontierOfLengthCodeSearchGap
    left_family right_family lengthCodeAt time_bound_strict exponent_ne_zero
    (projectLengthCheckedLowerBoundSearchGap checked_lower)
    lengthCodeAt_eq_conj_source
    left_length_polynomial right_length_polynomial

/-! ## Project-length measured object -/

/-- The theorem-5 power-bound family measured by the concrete checker
`projectLength` semantics.  This is the replacement measured object for the
root `proof_length` box on the theorem-5 raw-code family. -/
noncomputable def checkerProjectLengthMeasured
    (scale_data : InternalPudlakTheorem5ScaleData)
    (checker : InternalPudlakTheorem5CheckerSemantics.{0} scale_data)
    (fallback : _root_.FormulaCode → Nat) : Nat → Real :=
  fun n =>
    checker.toProofCodeSemantics.projectLength fallback
      (scale_data.powerBoundRawCode n)

theorem checkerProjectLengthMeasured_eq_checked
    {scale_data : InternalPudlakTheorem5ScaleData}
    {checker : InternalPudlakTheorem5CheckerSemantics.{0} scale_data}
    (fallback : _root_.FormulaCode → Nat) (n : Nat) :
    checkerProjectLengthMeasured scale_data checker fallback n =
      month9_month10_checkedProofCodeMeasured
        scale_data checker.toProofCodeSemantics n := by
  rw [checkerProjectLengthMeasured,
    _root_.ProofCodeSemantics.projectLength_eq_minProofCodeSize]
  rfl

theorem projectLengthScale_injective_of_scale_strict
    {scale_data : InternalPudlakTheorem5ScaleData}
    (scale_strict :
      ∀ {a b : Nat}, a < b → scale_data.scale a < scale_data.scale b) :
    Function.Injective scale_data.scale := by
  intro a b hscale_eq
  rcases Nat.lt_trichotomy a b with hlt | heq | hgt
  · have hstrict : scale_data.scale a < scale_data.scale b :=
      scale_strict hlt
    rw [hscale_eq] at hstrict
    exact False.elim ((Nat.lt_irrefl _) hstrict)
  · exact heq
  · have hstrict : scale_data.scale b < scale_data.scale a :=
      scale_strict hgt
    rw [hscale_eq] at hstrict
    exact False.elim ((Nat.lt_irrefl _) hstrict)

theorem projectLengthPowerBoundRawCode_injective_of_scale_strict
    {scale_data : InternalPudlakTheorem5ScaleData}
    (scale_strict :
      ∀ {a b : Nat}, a < b → scale_data.scale a < scale_data.scale b) :
    Function.Injective scale_data.powerBoundRawCode :=
  concretePAHilbert_powerBoundRawCode_injective_of_scale_injective
    scale_data (projectLengthScale_injective_of_scale_strict scale_strict)

theorem projectLengthPowerBoundRawCode_injective_of_timeBound
    {scale_data : InternalPudlakTheorem5ScaleData}
    (time_bound_strict :
      ∀ {a b : Nat}, a < b →
        scale_data.time_constructible_bound a <
          scale_data.time_constructible_bound b)
    (exponent_ne_zero : scale_data.exponent ≠ 0) :
    Function.Injective scale_data.powerBoundRawCode :=
  projectLengthPowerBoundRawCode_injective_of_scale_strict
    (Month9Month10ActualProofLengthGapFrontier.scale_strict_of_timeConstructibleBound_strict
      time_bound_strict exponent_ne_zero)

theorem calibratedCheckerProjectLengthMeasured_eq_lengthCodeAt_of_injective
    {scale_data : InternalPudlakTheorem5ScaleData}
    (lengthCodeAt : Nat → Nat)
    (fallback : _root_.FormulaCode → Nat)
    (hinjective : Function.Injective scale_data.powerBoundRawCode)
    (n : Nat) :
    checkerProjectLengthMeasured scale_data
        (concretePAHilbertPowerBoundCalibratedCheckerSemantics
          scale_data lengthCodeAt)
        fallback n =
      (lengthCodeAt n : Real) :=
  concretePAHilbertPowerBoundCalibrated_projectLengthAt_eq_lengthCodeAt_of_injective
    scale_data lengthCodeAt fallback n hinjective

theorem rootProofLength_eq_lengthCodeAt_of_calibratedCheckerExactness
    {scale_data : InternalPudlakTheorem5ScaleData}
    (lengthCodeAt : Nat → Nat)
    (fallback : _root_.FormulaCode → Nat)
    (hinjective : Function.Injective scale_data.powerBoundRawCode)
    (exactness :
      InternalPudlakTheorem5CheckerProofLengthExactness
        (concretePAHilbertPowerBoundCalibratedCheckerSemantics
          scale_data lengthCodeAt)) :
    ∀ n : Nat,
      _root_.proof_length _root_.ProofSystem.PA
          _root_.ProofLengthMeasure.symbolSize
          (scale_data.powerBoundRawCode n) =
        (lengthCodeAt n : Real) := by
  intro n
  calc
    _root_.proof_length _root_.ProofSystem.PA
        _root_.ProofLengthMeasure.symbolSize
        (scale_data.powerBoundRawCode n) =
        ((concretePAHilbertPowerBoundCalibratedCheckerSemantics
          scale_data lengthCodeAt).minProofCodeSizeAt n : Real) :=
          exactness.at_powerBoundRawCode n
    _ =
        checkerProjectLengthMeasured scale_data
          (concretePAHilbertPowerBoundCalibratedCheckerSemantics
            scale_data lengthCodeAt)
          fallback n := by
          rw [checkerProjectLengthMeasured_eq_checked]
          rfl
    _ = (lengthCodeAt n : Real) :=
        calibratedCheckerProjectLengthMeasured_eq_lengthCodeAt_of_injective
          lengthCodeAt fallback hinjective n

theorem rootProofLength_eq_lengthCodeAt_of_calibratedCheckerExactness_timeBound
    {scale_data : InternalPudlakTheorem5ScaleData}
    (lengthCodeAt : Nat → Nat)
    (time_bound_strict :
      ∀ {a b : Nat}, a < b →
        scale_data.time_constructible_bound a <
          scale_data.time_constructible_bound b)
    (exponent_ne_zero : scale_data.exponent ≠ 0)
    (fallback : _root_.FormulaCode → Nat)
    (exactness :
      InternalPudlakTheorem5CheckerProofLengthExactness
        (concretePAHilbertPowerBoundCalibratedCheckerSemantics
          scale_data lengthCodeAt)) :
    ∀ n : Nat,
      _root_.proof_length _root_.ProofSystem.PA
          _root_.ProofLengthMeasure.symbolSize
          (scale_data.powerBoundRawCode n) =
