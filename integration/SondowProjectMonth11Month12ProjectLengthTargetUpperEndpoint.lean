theorem s21GraftCanonicalCalibrationPackage_sondow_length_le_17_of_trace
    (h : _root_.S21GraftCanonicalCalibrationPackage)
    (htrace :
      _root_.S21VerifierTraceSoundness _root_.sondowCertificateValidCode)
    (n : Nat)
    (hacc :
      _root_.accepted_certificate (_root_.sondowCertificateValidCode n)) :
    (h.sondow_proofs.length n : Real) ≤
      (17 : Real) * ((n : Real) + 1) ^ (1 : Nat) := by
  exact le_trans
    (s21GraftCanonicalCalibrationPackage_sondow_length_le_proofPredicate_of_trace
      h htrace n hacc)
    (proofPredicateFormulaSizeSondowCertificateValidCode_le_17_natPower n)

/-- Natural-number version of the Sondow trace length bound.  This is the
finite-prefix certificate shape needed by the executable endpoint. -/
theorem s21GraftCanonicalCalibrationPackage_sondow_length_le_17_mul_succ_of_trace
    (h : _root_.S21GraftCanonicalCalibrationPackage)
    (htrace :
      _root_.S21VerifierTraceSoundness _root_.sondowCertificateValidCode)
    (n : Nat)
    (hacc :
      _root_.accepted_certificate (_root_.sondowCertificateValidCode n)) :
    h.sondow_proofs.length n ≤ 17 * (n + 1) := by
  have hreal :=
    s21GraftCanonicalCalibrationPackage_sondow_length_le_17_of_trace
      h htrace n hacc
  have hrealNat :
      (h.sondow_proofs.length n : Real) ≤
        ((17 * (n + 1) : Nat) : Real) := by
    simpa [pow_one, Nat.cast_mul, Nat.cast_add, Nat.cast_one] using hreal
  exact_mod_cast hrealNat

/-- A finite prefix of accepted Sondow certificates gives a uniform natural
length coefficient `17 * threshold` for the same prefix.  This avoids asking a
prefix checker to reason directly about the calibrated proof-family lengths. -/
theorem s21GraftCanonicalCalibrationPackage_sondow_prefix_length_le_17_mul_threshold_of_trace
    (h : _root_.S21GraftCanonicalCalibrationPackage)
    (htrace :
      _root_.S21VerifierTraceSoundness _root_.sondowCertificateValidCode)
    (threshold : Nat)
    (acceptedPrefix :
      ∀ n : Nat, n < threshold →
        _root_.accepted_certificate (_root_.sondowCertificateValidCode n)) :
    ∀ n : Nat, n < threshold → h.sondow_proofs.length n ≤ 17 * threshold := by
  intro n hn
  have hlen :
      h.sondow_proofs.length n ≤ 17 * (n + 1) :=
    s21GraftCanonicalCalibrationPackage_sondow_length_le_17_mul_succ_of_trace
      h htrace n (acceptedPrefix n hn)
  have hsucc : n + 1 ≤ threshold :=
    Nat.succ_le_of_lt hn
  exact Nat.le_trans hlen (Nat.mul_le_mul_left 17 hsucc)

