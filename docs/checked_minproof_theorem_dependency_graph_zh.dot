digraph CheckedMinProofMain {
  graph [
    rankdir=TB,
    bgcolor="white",
    compound=true,
    newrank=true,
    splines=polyline,
    nodesep="0.28",
    ranksep="0.46",
    pad="0.18",
    size="12,18!",
    ratio=compress,
    fontname="Noto Sans CJK SC",
    fontsize=22,
    label="最短证明增长下界：主定理依赖图（2026-07-13）",
    labelloc="t"
  ];
  node [
    shape=box,
    style="rounded,filled",
    fontname="Noto Sans CJK SC",
    fontsize=10.5,
    color="#526d75",
    fillcolor="#f3f3f3",
    margin="0.14,0.09",
    penwidth=1.2
  ];
  edge [
    fontname="Noto Sans CJK SC",
    fontsize=8.5,
    color="#65777d",
    arrowsize=0.68,
    penwidth=1.05
  ];

  subgraph cluster_legend {
    label="状态";
    color="#c8d1d4";
    style="rounded";
    legend_done [label="绿色：Lean 内核已检查", fillcolor="#dff2e8", color="#3f7c66"];
    legend_active [label="黄色：唯一当前工作面", fillcolor="#fff0c9", color="#b37a12", penwidth=2.4];
    legend_pending [label="灰色：等待前置定理", style="rounded,filled,dashed", color="#777777"];
    legend_rejected [label="红色：弃用路线", fillcolor="#f8d9d6", color="#a8443d", style="rounded,filled,dashed"];
  }

  coordinate [
    node_id="M01", status="done",
    endpoint_theorem="packedPayloadLength + canonical accepted proof coordinate",
    source="integration/FoundationCompactListedMinProofLength.lean",
    appendix="checked_minproof_appendix_01_syntax_coordinate_zh.dot",
    next_obligation="none",
    label="M01 诚实证明坐标\nproof + certificate 全部计长\n规范码与最短完整载荷",
    fillcolor="#dff2e8", color="#3f7c66"
  ];
  checker [
    node_id="M02", status="done",
    endpoint_theorem="listedCompactCertifiedPAProofVerifier soundness/completeness",
    source="integration/FoundationCompactListedCertifiedVerifier.lean",
    appendix="checked_minproof_appendix_02_parser_traces_zh.dot",
    next_obligation="none",
    label="M02 真实 PA 检查器\n接受码 <-> 同公式 Derivation2\n无隐藏辅助见证",
    fillcolor="#dff2e8", color="#3f7c66"
  ];
  minmeasure [
    node_id="M03", status="done",
    endpoint_theorem="minListedCertifiedPAProofPayloadLength",
    source="integration/FoundationCompactListedMinProofLength.lean",
    appendix="checked_minproof_appendix_01_syntax_coordinate_zh.dot",
    next_obligation="none",
    label="M03 检查器诱导的最短长度\n无项目级 proof_length\n最小值由规范接受码实现",
    fillcolor="#dff2e8", color="#3f7c66"
  ];

  direct_partial [
    node_id="M04", status="partial_done",
    endpoint_theorem="146 checked direct-arithmeticization components",
    source="docs/checked_minproof_theorem_dependency_graph_legacy_20260712_zh.dot",
    appendix="checked_minproof_appendix_03_verifier_predicate_zh.dot",
    next_obligation="reuse only after the generic proof compiler exists",
    label="M04 直接算术化的已检查部件\n语法、表格、初终态等 146 项可复用\n尚未形成完整 P_direct",
    fillcolor="#dff2e8", color="#3f7c66"
  ];
  branch_route [
    node_id="X01", status="rejected",
    endpoint_theorem="none",
    source="integration/FoundationCompactNumericListedDirectParserSyntaxStepFormula.lean",
    appendix="checked_minproof_theorem_dependency_graph_legacy_20260712_zh.dot",
    next_obligation="do not resume branch-by-branch expansion",
    label="X01 逐解析器分支无限展开\n可产生局部绿点但不能可靠到达短证明编译器\n已暂停，不通向主结论",
    fillcolor="#f8d9d6", color="#a8443d", style="rounded,filled,dashed"
  ];

  compiler_core [
    node_id="M05", status="done",
    endpoint_theorem="CertifiedPAProof proof-producing quantitative core",
    source="integration/FoundationCompactPAQuantitativeCompilerCore.lean",
    appendix="checked_minproof_appendix_04_pa_quantitative_compiler_zh.dot",
    next_obligation="closed atomic arithmetic compiler",
    label="M05 真实 PA 定量证明产生核心\n公理实例化、MP、合取、存在引入\n实际推导 + 证书 + 完整载荷界",
    fillcolor="#dff2e8", color="#2f6f57", penwidth=2.8
  ];
  binary_base [
    node_id="M06", status="done",
    endpoint_theorem="short binary numeral certified PA proof bounds",
    source="integration/FoundationCompactPABinaryNumeralCompiler.lean",
    appendix="checked_minproof_appendix_04_pa_quantitative_compiler_zh.dot",
    next_obligation="normalize nontrivial binary arithmetic",
    label="M06 短二进制数词证明基元\n公开检查器接受\n载荷为 Nat.size(n) 的显式三次多项式",
    fillcolor="#dff2e8", color="#2f6f57", penwidth=2.8
  ];
  binary_normalizer [
    node_id="M07", status="done",
    endpoint_theorem="proveBinaryNumeralAddition_checked_polynomial + proveBinaryNumeralMultiplication_checked_polynomial",
    source="integration/FoundationCompactPABinaryNumeralAdditionBounds.lean + integration/FoundationCompactPABinaryNumeralMultiplicationBounds.lean",
    appendix="checked_minproof_appendix_04_pa_quantitative_compiler_zh.dot",
    next_obligation="none",
    label="M07 二进制等式归一化\n加法与乘法均产生真实 PA 证明\n公开检查器均接受\n完整载荷均有总输入位宽固定多项式界\n定向构建通过；公理画像仅标准三项",
    fillcolor="#dff2e8", color="#2f6f57", penwidth=2.8
  ];
  atomic_compiler [
    node_id="M08", status="done",
    endpoint_theorem="ClosedPAAtomicLiteralBounds.compile_checked_polynomial",
    source="integration/FoundationCompactPAClosedAtomicCompiler.lean + integration/FoundationCompactPAClosedAtomicCompilerBounds.lean",
    appendix="checked_minproof_appendix_04_pa_quantitative_compiler_zh.dot",
    next_obligation="none",
    label="M08 闭算术原子文字编译器\n=、≠、<、¬<、≤、¬≤ 六类统一真值证书\n同公式真实 PA 证明 + 公开检查器 + 固定多项式载荷界\n定向构建与清洁扫描通过；公理画像仅标准三项",
    fillcolor="#dff2e8", color="#2f6f57", penwidth=2.8
  ];
  bounded_compiler [
    node_id="M09", status="done",
    endpoint_theorem="CheckedClosedBoundedFormulaCertificate.compile_checked_polynomial",
    source="integration/FoundationCompactPABoundedFormulaCompiler.lean + integration/FoundationCompactPABoundedFormulaCompilerBounds.lean + integration/FoundationCompactPABoundedUniversalPolynomialBounds.lean",
    appendix="checked_minproof_appendix_04_pa_quantitative_compiler_zh.dot",
    next_obligation="none",
    label="M09 有界公式见证编译器\n原子、合取、析取、存在见证与有限有界全称均产生真实 PA 证明\n诚实 proof-free 证书编码 + 公开检查器 + 统一固定多项式完整载荷界\n有限穷举、归纳、分支输运和全称引入全部计长\n定向构建与清洁扫描通过；公理画像仅标准三项",
    fillcolor="#dff2e8", color="#2f6f57", penwidth=2.8
  ];
  direct_predicate [
    node_id="M10", status="done",
    endpoint_theorem="compactListedPADirectProofFormula_iff_exists_publicVerifier",
    source="integration/FoundationCompactNumericListedDirectProofPredicate.lean + integration/FoundationCompactNumericListedTaskMachineSyntaxInversion.lean + integration/FoundationCompactNumericListedDirectProofPredicateExactness.lean",
    appendix="checked_minproof_appendix_03_verifier_predicate_zh.dot",
    next_obligation="none",
    label="M10 同一检查器的 P_direct\n显式二变量 Sigma-one 公式已闭合\n逐点 iff 同一公开检查器在同一 formulaCode 上接受\n同一 proof + certificate 载荷码及 packedPayloadLength 度量\n反向语法恢复、探针与禁用扫描通过；公理画像仅标准三项",
    fillcolor="#dff2e8", color="#2f6f57", penwidth=2.8
  ];
  accepted_trace [
    node_id="M11", status="active",
    endpoint_theorem="accepted trace -> short certified PA proof of P_direct instance",
    source="integration/FoundationCompactPABoundedFormulaCompiler.lean + integration/FoundationCompactNumericListedDirectProofPredicateExactness.lean",
    appendix="checked_minproof_appendix_04_pa_quantitative_compiler_zh.dot",
    next_obligation="instantiate the checked bounded-formula compiler at the fixed P_direct matrix",
    label="M11【当前】接受轨迹到 PA 短证明\n将已闭合 P_direct 的显式有界矩阵交给 A04.17 编译器\n输出真实 proof object，不是存在性接口\n统一输入完整载荷长度的固定多项式界",
    fillcolor="#fff0c9", color="#b37a12", penwidth=3.0
  ];

  pudlak_conditions [
    node_id="M12", status="pending",
    endpoint_theorem="Pudlak quantitative conditions (0)-(3)",
    source="planned",
    appendix="checked_minproof_appendix_05_pudlak_collision_zh.dot",
    next_obligation="wait for M11",
    label="M12 Pudlak 条件 (0)-(3)\n同一 P_direct、PA 系统与完整载荷度量\n全部证明变换有固定多项式界",
    style="rounded,filled,dashed", color="#777777"
  ];
  pudlak_theorem [
    node_id="M13", status="pending",
    endpoint_theorem="Pudlak 1986 Theorem 3.1",
    source="planned",
    appendix="checked_minproof_appendix_05_pudlak_collision_zh.dot",
    next_obligation="quantitative diagonalization and bounded proof assembly",
    label="M13 Pudlak 定量下界\n对角化 + 有界证明拼接 + 指数提取",
    style="rounded,filled,dashed", color="#777777"
  ];
  buss_theorem [
    node_id="M14", status="pending",
    endpoint_theorem="Buss 1994 Theorem 5 rescaling",
    source="planned",
    appendix="checked_minproof_appendix_05_pudlak_collision_zh.dot",
    next_obligation="wait for M13",
    label="M14 Buss 第 5 定理重标定\n同一有限一致性公式族的超多项式下界",
    style="rounded,filled,dashed", color="#777777"
  ];
  lower [
    node_id="M15", status="pending",
    endpoint_theorem="eventual super-polynomial min-proof lower bound",
    source="planned",
    appendix="checked_minproof_appendix_05_pudlak_collision_zh.dot",
    next_obligation="wait for M14",
    label="M15 同对象证明长度下界\nminProof(F_n) > U(n) eventually",
    style="rounded,filled,dashed", color="#777777"
  ];

  sondow_cert [
    node_id="M16", status="done_boundary",
    endpoint_theorem="checked Sondow certificates",
    source="existing Sondow route",
    appendix="checked_minproof_appendix_05_pudlak_collision_zh.dot",
    next_obligation="same-object compiler still required",
    label="M16 索多已检查证书\n这里只表示证书层已检查\n不等于同对象上界已完成",
    fillcolor="#dff2e8", color="#3f7c66"
  ];
  sondow_bridge [
    node_id="M17", status="pending",
    endpoint_theorem="Sondow certificate -> proof of the same F_n",
    source="planned",
    appendix="checked_minproof_appendix_05_pudlak_collision_zh.dot",
    next_obligation="wait for formula identity M10 and proof compiler M11",
    label="M17 索多同对象编译器\n证书 -> 同一 F_n 的规范 PA 证明\n给出多项式上界",
    style="rounded,filled,dashed", color="#777777"
  ];
  upper [
    node_id="M18", status="pending",
    endpoint_theorem="minProof(F_n) <= U(n)",
    source="planned",
    appendix="checked_minproof_appendix_05_pudlak_collision_zh.dot",
    next_obligation="wait for M17",
    label="M18 同对象多项式上界\nminProof(F_n) <= U(n)",
    style="rounded,filled,dashed", color="#777777"
  ];
  audit_gate [
    node_id="M19", status="pending",
    endpoint_theorem="same formula/parameter/checker/measure audit",
    source="planned",
    appendix="checked_minproof_appendix_05_pudlak_collision_zh.dot",
    next_obligation="wait for M15 and M18",
    label="M19 最终依赖审计\n同一 n、F_n、检查器、完整载荷度量\n无项目公设、无循环输入",
    fillcolor="#e9e3f5", color="#76639a", style="rounded,filled,dashed"
  ];
  collision [
    node_id="M20", status="pending",
    endpoint_theorem="U(N) < minProof(F_N) <= U(N)",
    source="planned",
    appendix="checked_minproof_appendix_05_pudlak_collision_zh.dot",
    next_obligation="wait for M19",
    label="M20 对撞定理\nU(N) < minProof(F_N) <= U(N)",
    fillcolor="#f3f3f3", color="#777777", style="rounded,filled,dashed", penwidth=2.2
  ];
  final [
    node_id="M21", status="pending",
    endpoint_theorem="not is_rational euler_mascheroni",
    source="planned",
    appendix="checked_minproof_appendix_05_pudlak_collision_zh.dot",
    next_obligation="wait for M20",
    label="M21 最终非有理性结论\n只在全部上游根定理闭合后成立",
    fillcolor="#f3f3f3", color="#777777", style="rounded,filled,dashed", penwidth=2.2
  ];

  coordinate -> checker -> minmeasure;
  checker -> compiler_core;
  coordinate -> compiler_core;
  compiler_core -> binary_base -> binary_normalizer;
  binary_normalizer -> atomic_compiler -> bounded_compiler;
  direct_partial -> direct_predicate [style=dotted, label="只复用已审计部件"];
  bounded_compiler -> direct_predicate;
  bounded_compiler -> accepted_trace;
  direct_predicate -> accepted_trace;
  accepted_trace -> pudlak_conditions -> pudlak_theorem -> buss_theorem -> lower;
  minmeasure -> lower [style=dotted];
  sondow_cert -> sondow_bridge -> upper;
  direct_predicate -> sondow_bridge [style=dotted, label="公式恒等"];
  accepted_trace -> sondow_bridge [style=dotted, label="同一证明编译器"];
  minmeasure -> upper [style=dotted];
  lower -> audit_gate;
  upper -> audit_gate;
  checker -> audit_gate [style=dotted];
  audit_gate -> collision -> final;
  direct_partial -> branch_route [style=dashed, color="#a8443d", arrowhead=none];
}
