    rootdispatchdecomp -> rootfieldtrace [label="same five field shapes selected by ten tags\n十标签选择同一五类字段形状"];
    sequentvaluetrace -> rootfieldtrace [label="checked sequent and per-formula traces\n已检查序列及逐公式轨迹"];
    termclosedtrace -> rootfieldtrace [label="checked term and closed-formula traces\n已检查项及闭公式轨迹"];
    localtableau -> directtrace [label="public witness uses local validity\n公开见证使用局部有效性"];
    packedstreamtrace -> directtrace [label="two public input subtraces\n两份公开输入子轨迹"];
    parseroutertrace -> directtrace [label="three parser local subtraces\n三份解析器局部子轨迹"];
    parseresultdecomp -> directtrace [label="wrapper-free explicit parse data\n无包装黑箱的显式解析数据"];
    predicate -> directtrace [label="exact accepted-code equivalence\n接受码关系精确等价"];
    directtrace -> roottraceintegration [label="same public total witness semantics\n同一公开总见证语义"];
    rootfieldtrace -> rootdirectdispatch [label="five shapes selected by exact public tags\n五类形状由公开标签精确选择"];
    rootdirectdispatch -> rootresidualtrace [label="replace old branch-result relation\n替换旧分支结果关系"];
    parseresultdecomp -> rootresidualtrace [label="same certified-parts exact decomposition\n同一已认证部件精确分解"];
    rootresidualtrace -> roottraceintegration [label="explicit residual field\n显式剩余关系字段"];
    roottraceintegration -> additivecodecbase [label="typed public trace data\n类型化公开轨迹数据"];
    defaultlistcode -> additivecodecbase [style=dotted, arrowhead=none, constraint=false, label="rejected default; motivates additive codec\n否决默认编码；改用加法型编码"];
    additivecodecbase -> additiveweightexact [label="charge every token payload and delimiter\n逐 token 支付载荷与分隔成本"];
    additiveweightexact -> directtracecode [label="instantiate exact additive measure on the full trace\n把精确加法度量实例化到完整轨迹"];
    directtracecode -> tracecomponentdecomp [label="open the public witness at semantic component boundaries\n在语义分量边界打开公开见证"];
    tracecomponentdecomp -> statetableaggregation [label="isolate and aggregate the largest component\n隔离并汇总最大的状态表分量"];
    statetableaggregation -> nodesuffixinversion [label="first atomic row invariant: parser suffixes\n第一项逐行原子不变量：解析后缀"];
    nodesuffixinversion -> streamsuffixinvariant [label="lift through every control branch and iterate\n提升到全部控制分支与迭代"];
    streamsuffixinvariant -> streamweightbound [label="convert exact suffixes to honest additive weights\n把精确后缀转为诚实加法位权"];
    streamweightbound -> parsedvalueweight [label="bound every parsed syntax segment and nested sequent\n约束每个解析语法片段与嵌套序列"];
    streamweightbound -> stackcountbound [label="bound the number of stored items along every run\n约束全程存储项目数量"];
    parsedvalueweight -> nodefieldweights [label="assemble each concrete parser shape\n组装每种具体解析形状"];
    nodefieldweights -> dispatcherfieldweights [label="lift five shapes through public tags 0..9\n把五种形状提升到公开标签 0..9"];
    dispatcherfieldweights -> itemsourceinvariant [label="new parsed fields enter the task/child stacks\n新解析字段进入任务/子结果栈"];
    stackcountbound -> itemsourceinvariant [label="same two runtime stacks\n同两条运行栈"];
    itemsourceinvariant -> stateexplicitbound [label="discharge every per-item premise in the row budget\n消去单行预算的全部逐项前提"];
    statetableaggregation -> stateexplicitbound [label="instantiate the generic row/table aggregation\n实例化通用行/表汇总引理"];
    remainingtracebounds [label="Bounds for trace components 1..11\n直接轨迹前十一个分量的位权界\n\nLean 内核已检查，完成 11/11：\n1/3/8/9/11 五个数据值分量；\n2/4 两份 packed-stream trace；\n5/6/7 proof/certificate/formula 三份 parser state trace；\n10. root-field nested direct trace。\n\n第 10 项进一步打开：\n1. sequent count 由成功解析推出 count <= token weight，\n   排除二进制 count 导致的指数表长；\n2. count+1 个外层状态与 count 个逐公式 parser 轨迹逐项有界；\n3. term 与真实 closed-formula 执行机分别建立来源/栈高/整表界；\n4. 五种字段形状及标签 0..9 全部分派到同一公开预算；\n5. 最终只依赖 Nat.size(code)。\n\n全部关键端点公理画像仅\npropext / Classical.choice / Quot.sound；\n无 sorryAx、无项目公设。\nFoundationCompactNumericListedDirectTraceBounds.lean", fillcolor="#dff2e8", color="#2f6f57", penwidth=3.2];
    stateexplicitbound -> remainingtracebounds [label="continue with components 1..11\n继续关闭前十一个分量"];
    remainingtracebounds -> boundedtracecode [label="encode the bounded complete trace as one Nat certificate\n把有界完整轨迹编码为单一自然数证书"];
    boundedtracecode -> natsizegraph [label="arithmetize the honest binary-size guard\n算术化诚实二进制码长守卫"];
    natsizegraph -> packedpayloadgraph [label="separate exact payload length from the terminal sentinel\n分离精确载荷长度与终止哨兵"];
    packedpayloadgraph -> binarynattokengraph [label="one exact self-delimiting Nat segment\n一个精确自定界自然数段"];
    binarynattokengraph -> fixedwidthtablegraph [label="store token values and offsets in polynomial-size rows\n把 token 值与偏移存入多项式大小行"];
    fixedwidthtablegraph -> tokenstreamforward [label="construct canonical token and offset tables\n构造规范 token 表与偏移表"];
    tokenstreamforward -> tokenstreaminverse [label="unique inverse extraction\n唯一反向提取"];
    tokenstreaminverse -> directinputtableau [label="normalize both public inputs at the bounded predicate\n在有界谓词层规范化两条公开输入"];
    directinputtableau -> additivecursorgraph [label="read canonical token tables by bounded cursors\n用有界游标读取规范 token 表"];
    additivecursorgraph -> tracecomponenttableau [label="construct thirteen exact top-level boundaries\n构造十三个精确顶层边界"];
    tracecomponenttableau -> additivetypelayouts [label="supply recursive codec constructors\n提供递归编码构造子"];
    additivetypelayouts -> tracenatlistslices [label="instantiate the three top-level Nat lists\n实例化三个顶层自然数列表"];
    tracenatlistslices -> packedstreamsplits [label="split the two stream-trace products\n分割两份流轨迹积类型"];
    packedstreamsplits -> structuredlistcanonical [label="construct shifted element-boundary tables\n构造移位元素边界表"];
    structuredlistcanonical -> packedstreamlistlayouts [label="instantiate four stream-trace list fields\n实例化四个流轨迹列表字段"];
    packedstreamlistlayouts -> additivetypecanonical [label="construct exact element-layout witnesses\n构造精确元素布局见证"];
    additivetypecanonical -> atomiclistlayouts [label="lift atomic witnesses to every list row\n把原子见证提升到全部列表行"];
    additivetypecanonical -> streamstatuslayout [label="open the nested status options and output list\n打开双层状态选项与输出列表"];
    streamstatuslayout -> streamstatelayout [label="assemble one complete stream state\n汇总单个完整流状态"];
    atomiclistlayouts -> streamstatelayout [label="read every bits/decoded atom\n读取 bits/decoded 的每个原子"];
    streamstatelayout -> statelistrowlayout [label="tie each canonical row to its real state\n把每个规范行接到真实状态"];
